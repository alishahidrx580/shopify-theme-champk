<section
  class="page-cards-row full-width"
  style="--margin-top: {{ section.settings.margin_top }}rem; --margin-bottom: {{ section.settings.margin_bottom }}rem;"
>
  <div class="page-cards-row__inner">
    <div class="page-cards-row__grid">
      {%- for block in section.blocks -%}
        <div
          class="page-cards-row__card"
          data-reveal
          data-reveal-delay="{{ forloop.index | times: 100 }}"
          {{ block.shopify_attributes }}
        >
          <h3 class="page-cards-row__title font-display">{{ block.settings.title }}</h3>
          <div class="page-cards-row__body">{{ block.settings.body }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .page-cards-row {
    width: 100%;
    margin-top: var(--margin-top, 6rem);
    margin-bottom: var(--margin-bottom, 8rem);
  }

  @media (min-width: 1024px) {
    .page-cards-row {
      margin-top: calc(var(--margin-top, 6rem) + 2rem);
    }
  }

  .page-cards-row__inner {
    max-width: 1100px;
    margin-inline: auto;
    padding-inline: var(--page-padding-inline);
  }

  @media (min-width: 1024px) {
    .page-cards-row__inner {
      padding-inline: var(--page-padding-inline-lg);
    }
  }

  .page-cards-row__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .page-cards-row__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .page-cards-row__card {
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }

  .page-cards-row__title {
    font-size: 1.5rem;
    line-height: 1.1;
  }

  @media (min-width: 1024px) {
    .page-cards-row__title {
      font-size: 1.875rem;
    }
  }

  .page-cards-row__body {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: color-mix(in oklab, var(--foreground) 75%, transparent);
    line-height: 1.65;
  }

  .page-cards-row__body > p {
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Cards row",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top margin (mobile)",
      "min": 0,
      "max": 16,
      "step": 1,
      "unit": "rem",
      "default": 6
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom margin",
      "min": 0,
      "max": 16,
      "step": 1,
      "unit": "rem",
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Cards row"
    }
  ]
}
{% endschema %}
