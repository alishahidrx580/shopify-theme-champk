{%- liquid
  # Build the hero image pool: section image + non-blank blocks.
  # Rotation happens client-side at a configurable interval, with Ken Burns
  # (slow zoom + gentle pan) motion on every slide for a cinematic feel.
  #
  # Mobile gets fully independent: image, focal point, height, and motion.
  # Falls back to desktop values when mobile equivalents aren't set.

  assign rotation_seconds = section.settings.rotation_seconds | default: 6
  assign fade_ms = section.settings.fade_ms | default: 800

  # ===== Desktop Ken Burns preset =====
  assign kb_preset = section.settings.kb_preset | default: 'whisper'

  if kb_preset == 'whisper'
    assign kb_zoom_from = 1.00
    assign kb_zoom_to = 1.06
    assign kb_duration_s = 18
  elsif kb_preset == 'editorial'
    assign kb_zoom_from = 1.00
    assign kb_zoom_to = 1.10
    assign kb_duration_s = 14
  elsif kb_preset == 'cinematic'
    assign kb_zoom_from = 1.00
    assign kb_zoom_to = 1.18
    assign kb_duration_s = 11
  elsif kb_preset == 'lively'
    assign kb_zoom_from = 1.00
    assign kb_zoom_to = 1.25
    assign kb_duration_s = 9
  elsif kb_preset == 'custom'
    assign kb_zoom_from = 1.00
    assign kb_zoom_to_raw = section.settings.kb_zoom_to | default: 110
    assign kb_zoom_to = kb_zoom_to_raw | times: 1.0 | divided_by: 100.0
    assign kb_duration_s = section.settings.kb_duration_s | default: 14
  elsif kb_preset == 'off'
    assign kb_zoom_from = 1.00
    assign kb_zoom_to = 1.00
    assign kb_duration_s = 1
  else
    assign kb_zoom_from = 1.00
    assign kb_zoom_to = 1.06
    assign kb_duration_s = 18
  endif

  # ===== Mobile Ken Burns preset (independent of desktop) =====
  assign kb_preset_mobile = section.settings.kb_preset_mobile | default: 'inherit'

  if kb_preset_mobile == 'inherit'
    assign kb_zoom_from_m = kb_zoom_from
    assign kb_zoom_to_m = kb_zoom_to
    assign kb_duration_s_m = kb_duration_s
  elsif kb_preset_mobile == 'whisper'
    assign kb_zoom_from_m = 1.00
    assign kb_zoom_to_m = 1.06
    assign kb_duration_s_m = 18
  elsif kb_preset_mobile == 'editorial'
    assign kb_zoom_from_m = 1.00
    assign kb_zoom_to_m = 1.10
    assign kb_duration_s_m = 14
  elsif kb_preset_mobile == 'cinematic'
    assign kb_zoom_from_m = 1.00
    assign kb_zoom_to_m = 1.18
    assign kb_duration_s_m = 11
  elsif kb_preset_mobile == 'lively'
    assign kb_zoom_from_m = 1.00
    assign kb_zoom_to_m = 1.25
    assign kb_duration_s_m = 9
  elsif kb_preset_mobile == 'off'
    assign kb_zoom_from_m = 1.00
    assign kb_zoom_to_m = 1.00
    assign kb_duration_s_m = 1
  else
    assign kb_zoom_from_m = kb_zoom_from
    assign kb_zoom_to_m = kb_zoom_to
    assign kb_duration_s_m = kb_duration_s
  endif

  # Mobile heights with sensible defaults.
  assign min_height_svh_mobile = section.settings.min_height_svh_mobile | default: section.settings.min_height_svh
  assign min_height_px_mobile = section.settings.min_height_px_mobile | default: section.settings.min_height_px

  # Determine first/initial DESKTOP image for SSR (LCP-friendly).
  assign initial_image = section.settings.image
  assign initial_pos_x = section.settings.position_x | default: 50
  assign initial_pos_y = section.settings.position_y | default: 50

  if initial_image == blank
    for block in section.blocks
      if block.settings.image != blank
        assign initial_image = block.settings.image
        assign initial_pos_x = block.settings.position_x | default: 50
        assign initial_pos_y = block.settings.position_y | default: 50
        break
      endif
    endfor
  endif

  # Determine first/initial MOBILE image. Falls back to desktop image when blank.
  assign initial_image_mobile = section.settings.image_mobile
  assign initial_pos_x_m = section.settings.position_x_mobile | default: section.settings.position_x | default: 50
  assign initial_pos_y_m = section.settings.position_y_mobile | default: section.settings.position_y | default: 50

  if initial_image_mobile == blank
    for block in section.blocks
      if block.settings.image_mobile != blank
        assign initial_image_mobile = block.settings.image_mobile
        assign initial_pos_x_m = block.settings.position_x_mobile | default: block.settings.position_x | default: 50
        assign initial_pos_y_m = block.settings.position_y_mobile | default: block.settings.position_y | default: 50
        break
      endif
    endfor
  endif
-%}

<section
  class="home-hero full-width{% if kb_preset == 'off' %} home-hero--no-motion{% endif %}{% if kb_preset_mobile == 'off' %} home-hero--no-motion-mobile{% endif %}"
  style="
    --min-height-svh: {{ section.settings.min_height_svh }}svh;
    --min-height-px: {{ section.settings.min_height_px }}px;
    --min-height-svh-m: {{ min_height_svh_mobile }}svh;
    --min-height-px-m: {{ min_height_px_mobile }}px;
    --kb-zoom-from: {{ kb_zoom_from }};
    --kb-zoom-to: {{ kb_zoom_to }};
    --kb-duration: {{ kb_duration_s }}s;
    --kb-zoom-from-m: {{ kb_zoom_from_m }};
    --kb-zoom-to-m: {{ kb_zoom_to_m }};
    --kb-duration-m: {{ kb_duration_s_m }}s;
  "
  data-rotation-ms="{{ rotation_seconds | times: 1000 }}"
  data-fade-ms="{{ fade_ms }}"
>
  <div class="home-hero__media" aria-hidden="true">
    {%- if initial_image != blank or initial_image_mobile != blank -%}
      {%- # First slide: <picture> with mobile source + desktop fallback for LCP. -%}
      {%- assign desktop_src = initial_image | default: initial_image_mobile -%}
      {%- assign mobile_src = initial_image_mobile | default: initial_image -%}

      <picture
        class="home-hero__image is-active"
        data-slide="0"
        data-kb-dir="0"
        style="--pos-x: {{ initial_pos_x }}%; --pos-y: {{ initial_pos_y }}%; --pos-x-m: {{ initial_pos_x_m }}%; --pos-y-m: {{ initial_pos_y_m }}%;"
      >
        {%- if mobile_src != blank -%}
          <source
            media="(max-width: 767px)"
            srcset="{{ mobile_src | image_url: width: 600 }} 600w, {{ mobile_src | image_url: width: 900 }} 900w, {{ mobile_src | image_url: width: 1200 }} 1200w"
            sizes="100vw"
          >
        {%- endif -%}
        <img
          src="{{ desktop_src | image_url: width: 1920 }}"
          srcset="{{ desktop_src | image_url: width: 800 }} 800w, {{ desktop_src | image_url: width: 1280 }} 1280w, {{ desktop_src | image_url: width: 1920 }} 1920w, {{ desktop_src | image_url: width: 2560 }} 2560w"
          sizes="100vw"
          alt="{{ desktop_src.alt | default: 'general.brand.name' | t | escape }}"
          width="{{ desktop_src.width }}"
          height="{{ desktop_src.height }}"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        >
      </picture>

      {%- assign slide_index = 1 -%}

      {%- # Helper note: we need to walk blocks but skip the one already used as initial. -%}
      {%- assign desktop_initial_used = false -%}
      {%- if section.settings.image != blank -%}
        {%- assign desktop_initial_used = true -%}
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- assign block_desktop = block.settings.image -%}
        {%- assign block_mobile = block.settings.image_mobile -%}

        {%- # Skip empty blocks (no image at all). -%}
        {%- if block_desktop == blank and block_mobile == blank -%}{%- continue -%}{%- endif -%}

        {%- # If desktop section image was blank, the first non-blank block was already used as the initial slide — skip it here. -%}
        {%- if desktop_initial_used == false -%}
          {%- assign desktop_initial_used = true -%}
          {%- continue -%}
        {%- endif -%}

        {%- assign block_desktop_src = block_desktop | default: block_mobile -%}
        {%- assign block_mobile_src = block_mobile | default: block_desktop -%}

        {%- assign bx = block.settings.position_x | default: 50 -%}
        {%- assign by = block.settings.position_y | default: 50 -%}
        {%- assign bx_m = block.settings.position_x_mobile | default: block.settings.position_x | default: 50 -%}
        {%- assign by_m = block.settings.position_y_mobile | default: block.settings.position_y | default: 50 -%}
        {%- assign kb_dir = slide_index | modulo: 4 -%}

        <picture
          class="home-hero__image"
          data-slide="{{ slide_index }}"
          data-kb-dir="{{ kb_dir }}"
          style="--pos-x: {{ bx }}%; --pos-y: {{ by }}%; --pos-x-m: {{ bx_m }}%; --pos-y-m: {{ by_m }}%;"
        >
          {%- if block_mobile_src != blank -%}
            <source
              media="(max-width: 767px)"
              srcset="{{ block_mobile_src | image_url: width: 600 }} 600w, {{ block_mobile_src | image_url: width: 900 }} 900w, {{ block_mobile_src | image_url: width: 1200 }} 1200w"
              sizes="100vw"
            >
          {%- endif -%}
          <img
            src="{{ block_desktop_src | image_url: width: 1920 }}"
            srcset="{{ block_desktop_src | image_url: width: 800 }} 800w, {{ block_desktop_src | image_url: width: 1280 }} 1280w, {{ block_desktop_src | image_url: width: 1920 }} 1920w, {{ block_desktop_src | image_url: width: 2560 }} 2560w"
            sizes="100vw"
            alt="{{ block_desktop_src.alt | default: 'general.brand.name' | t | escape }}"
            width="{{ block_desktop_src.width }}"
            height="{{ block_desktop_src.height }}"
            loading="lazy"
            decoding="async"
          >
        </picture>

        {%- assign slide_index = slide_index | plus: 1 -%}
      {%- endfor -%}
    {%- else -%}
      <div class="home-hero__image home-hero__image--placeholder is-active" aria-hidden="true"></div>
    {%- endif -%}
  </div>

  <div class="home-hero__overlay" aria-hidden="true"></div>

  <div class="home-hero__inner">
    <div class="home-hero__content" data-reveal>
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow home-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h1 class="home-hero__heading font-display">
        {{- section.settings.heading_lead -}}
        {%- if section.settings.heading_break -%}<br>{%- endif -%}
        {%- if section.settings.heading_emphasis != blank -%}
          {%- unless section.settings.heading_break %} {% endunless -%}
          <em>{{ section.settings.heading_emphasis }}</em>
        {%- endif -%}
      </h1>

      {%- if section.settings.body != blank -%}
        <div class="home-hero__body">{{ section.settings.body }}</div>
      {%- endif -%}

      {%- if section.settings.cta_primary_label != blank or section.settings.cta_secondary_label != blank -%}
        <div class="home-hero__ctas">
          {%- if section.settings.cta_primary_label != blank -%}
            <a href="{{ section.settings.cta_primary_url | default: '#' }}" class="home-hero__cta-primary">
              {{ section.settings.cta_primary_label }}
            </a>
          {%- endif -%}
          {%- if section.settings.cta_secondary_label != blank -%}
            <a href="{{ section.settings.cta_secondary_url | default: '#' }}" class="home-hero__cta-secondary gold-link">
              {{ section.settings.cta_secondary_label }} →
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .home-hero {
    position: relative;
    /* Mobile-first: smaller, controllable. */
    height: var(--min-height-svh-m, 72svh);
    min-height: var(--min-height-px-m, 480px);
    width: 100%;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .home-hero {
      height: var(--min-height-svh, 100svh);
      min-height: var(--min-height-px, 640px);
    }
  }

  .home-hero__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* <picture> behaves like a block, so we restyle it to act like the previous
     <img>: absolutely positioned, fills the container. The inner <img> fills
     the picture element. */
  .home-hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity var(--hero-fade-ms, 800ms) ease-in-out;
    transform-origin: 50% 50%;
    will-change: opacity, transform;
    display: block;
  }

  .home-hero__image > img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Mobile-first focal point. */
    object-position: var(--pos-x-m, 50%) var(--pos-y-m, 50%);
    display: block;
  }

  @media (min-width: 768px) {
    .home-hero__image > img {
      object-position: var(--pos-x, 50%) var(--pos-y, 50%);
    }
  }

  .home-hero__image.is-active {
    opacity: 1;
    /* Transform is driven by JS for a continuous zoom flow across slides. */
  }

  /* Pan direction varies by slide so consecutive images don't feel identical. */
  .home-hero__image[data-kb-dir="0"] { transform-origin: 70% 30%; }
  .home-hero__image[data-kb-dir="1"] { transform-origin: 30% 70%; }
  .home-hero__image[data-kb-dir="2"] { transform-origin: 30% 30%; }
  .home-hero__image[data-kb-dir="3"] { transform-origin: 70% 70%; }

  .home-hero--no-motion .home-hero__image.is-active {
    transform: scale(1.02) !important;
  }

  .home-hero__image--placeholder {
    background: linear-gradient(135deg, oklch(0.25 0.02 70), oklch(0.15 0.01 60));
    opacity: 1;
  }

  .home-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgb(0 0 0 / 1), rgb(0 0 0 / 0.4) 50%, rgb(0 0 0 / 0.6));
    z-index: 1;
  }

  .home-hero__inner {
    position: relative;
    z-index: 2;
    height: 100%;
    max-width: var(--page-max-width);
    margin-inline: auto;
    padding-inline: var(--page-padding-inline);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: 3rem;
  }

  @media (min-width: 768px) {
    .home-hero__inner {
      padding-bottom: 5rem;
    }
  }

  @media (min-width: 1024px) {
    .home-hero__inner {
      padding-inline: var(--page-padding-inline-lg);
      padding-bottom: 7rem;
    }
  }

  .home-hero__eyebrow {
    color: var(--primary-glow);
    margin-bottom: 1rem;
    font-size: 0.625rem;
  }

  @media (min-width: 768px) {
    .home-hero__eyebrow {
      margin-bottom: 1.5rem;
      font-size: inherit;
    }
  }

  .home-hero__eyebrow::before {
    display: none;
  }

  .home-hero__heading {
    /* Mobile-first: smaller, more compact. */
    font-size: clamp(2.25rem, 11vw, 3.25rem);
    line-height: 1;
    color: #fff;
    max-width: 64rem;
    margin: 0;
  }

  @media (min-width: 768px) {
    .home-hero__heading {
      font-size: clamp(3.05rem, 9vw, 7.5rem);
      line-height: 0.95;
    }
  }

  .home-hero__heading em {
    color: var(--primary-glow);
    font-style: italic;
  }

  .home-hero__body {
    margin-top: 1.25rem;
    max-width: 28rem;
    font-size: 0.875rem;
    color: rgb(255 255 255 / 0.85);
    line-height: 1.6;
  }

  @media (min-width: 768px) {
    .home-hero__body {
      margin-top: 2rem;
      font-size: 1rem;
      line-height: 1.65;
    }
  }

  @media (min-width: 1024px) {
    .home-hero__body {
      font-size: 1.125rem;
    }
  }

  .home-hero__body > p {
    margin: 0;
  }

  .home-hero__ctas {
    margin-top: 1.75rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .home-hero__ctas {
      margin-top: 2.5rem;
      gap: 1.25rem;
    }
  }

  .home-hero__cta-primary {
    display: inline-block;
    padding: 0.875rem 1.75rem;
    background-color: var(--primary);
    color: var(--primary-foreground);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.6875rem;
    font-weight: 500;
    transition: background-color 0.3s ease;
  }

  @media (min-width: 768px) {
    .home-hero__cta-primary {
      padding: 1rem 2.25rem;
      font-size: 0.75rem;
    }
  }

  .home-hero__cta-primary:hover,
  .home-hero__cta-primary:focus-visible {
    background-color: var(--primary-glow);
  }

  .home-hero__cta-secondary {
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.6875rem;
    color: rgb(255 255 255 / 0.9);
    transition: color 0.3s ease;
  }

  @media (min-width: 768px) {
    .home-hero__cta-secondary {
      font-size: 0.75rem;
    }
  }

  .home-hero__cta-secondary:hover,
  .home-hero__cta-secondary:focus-visible {
    color: var(--primary-glow);
  }

  @media (max-height: 900px) and (min-width: 768px) {
    .home-hero__inner {
      padding-top: calc(var(--header-height, 4.5rem) + 0.75rem);
      padding-bottom: 3rem;
    }

    .home-hero__eyebrow {
      margin-bottom: 0.75rem;
    }

    .home-hero__heading {
      font-size: clamp(2.5rem, 7vh, 5rem);
    }

    .home-hero__body {
      margin-top: 1rem;
    }

    .home-hero__ctas {
      margin-top: 1.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-hero__image {
      transition: none;
    }
    .home-hero__image.is-active {
      transform: scale(1.02) !important;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    const heroes = Array.from(document.querySelectorAll('.home-hero'));

    heroes.forEach((root) => {
      const slides = Array.from(root.querySelectorAll('.home-hero__image'));
      if (slides.length === 0) return;

      const rotationMs = parseInt(root.dataset.rotationMs, 10) || 6000;
      const fadeMs = parseInt(root.dataset.fadeMs, 10) || 800;

      slides.forEach((s) => s.style.setProperty('--hero-fade-ms', fadeMs + 'ms'));

      // Mobile breakpoint matches the CSS (max-width: 767px = mobile, otherwise desktop).
      const mobileMQ = window.matchMedia('(max-width: 767px)');

      // Read both desktop and mobile zoom ranges; pick per current viewport.
      const cs = window.getComputedStyle(root);
      function readZoomRange() {
        const isMobile = mobileMQ.matches;
        const from = parseFloat(cs.getPropertyValue(isMobile ? '--kb-zoom-from-m' : '--kb-zoom-from')) || 1.0;
        const to = parseFloat(cs.getPropertyValue(isMobile ? '--kb-zoom-to-m' : '--kb-zoom-to')) || 1.06;
        return { from, to, isMobile };
      }

      let { from: zoomFrom, to: zoomTo, isMobile } = readZoomRange();

      const motionOffDesktop = root.classList.contains('home-hero--no-motion');
      const motionOffMobile = root.classList.contains('home-hero--no-motion-mobile');
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function isMotionOff() {
        if (reducedMotion) return true;
        const m = mobileMQ.matches;
        if (m && motionOffMobile) return true;
        if (!m && motionOffDesktop) return true;
        if (Math.abs(zoomTo - zoomFrom) < 0.001) return true;
        return false;
      }

      // ===== Static (no-motion) mode =====
      if (isMotionOff()) {
        slides.forEach((s, i) => {
          s.style.transform = 'scale(1.02)';
          if (i === 0) s.classList.add('is-active');
        });
        if (slides.length <= 1) return;

        let current = 0;
        const tick = () => {
          const next = (current + 1) % slides.length;
          slides[current].classList.remove('is-active');
          slides[next].classList.add('is-active');
          current = next;
        };
        let t = window.setInterval(tick, rotationMs);
        document.addEventListener('visibilitychange', () => {
          if (document.hidden) {
            window.clearInterval(t);
            t = null;
          } else if (t === null) {
            t = window.setInterval(tick, rotationMs);
          }
        });
        return;
      }

      // ===== Continuous zoom across slides =====
      let current = 0;
      let zoom = zoomFrom;
      let direction = 1;
      let lastTs = null;
      let rafId = null;
      let timer = null;

      slides.forEach((s, i) => {
        s.style.transform = 'scale(' + zoomFrom + ')';
        if (i === 0) s.classList.add('is-active');
      });

      function applyTransformToAll() {
        const t = 'scale(' + zoom.toFixed(4) + ')';
        for (let i = 0; i < slides.length; i++) {
          slides[i].style.transform = t;
        }
      }

      function frame(ts) {
        if (lastTs === null) lastTs = ts;
        const dt = ts - lastTs;
        lastTs = ts;

        const range = zoomTo - zoomFrom;
        const speed = range / rotationMs;
        zoom += direction * speed * dt;

        if (zoom > zoomTo) zoom = zoomTo;
        if (zoom < zoomFrom) zoom = zoomFrom;

        applyTransformToAll();
        rafId = window.requestAnimationFrame(frame);
      }

      function showNext() {
        const next = (current + 1) % slides.length;
        if (next === current) return;
        slides[current].classList.remove('is-active');
        slides[next].classList.add('is-active');
        direction *= -1;
        current = next;
      }

      function startLoop() {
        if (rafId === null) {
          lastTs = null;
          rafId = window.requestAnimationFrame(frame);
        }
        if (timer === null && slides.length > 1) {
          timer = window.setInterval(showNext, rotationMs);
        }
      }

      function stopLoop() {
        if (rafId !== null) {
          window.cancelAnimationFrame(rafId);
          rafId = null;
        }
        if (timer !== null) {
          window.clearInterval(timer);
          timer = null;
        }
      }

      // Re-read zoom range when viewport crosses the mobile/desktop boundary.
      function onViewportChange() {
        const next = readZoomRange();
        zoomFrom = next.from;
        zoomTo = next.to;
        // Clamp current zoom into the new range to avoid a visible jump.
        if (zoom > zoomTo) zoom = zoomTo;
        if (zoom < zoomFrom) zoom = zoomFrom;
      }
      if (typeof mobileMQ.addEventListener === 'function') {
        mobileMQ.addEventListener('change', onViewportChange);
      } else if (typeof mobileMQ.addListener === 'function') {
        mobileMQ.addListener(onViewportChange);
      }

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) stopLoop();
        else startLoop();
      });

      startLoop();
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.home_hero.name",
  "tag": "section",
  "class": "home-hero-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image",
      "info": "Recommended: 1920×1280 or 16:9. Use the focal point sliders below to adjust which part stays visible."
    },
    {
      "type": "range",
      "id": "position_x",
      "label": "Desktop — horizontal focal point",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "position_y",
      "label": "Desktop — vertical focal point",
