{%- liquid
  assign stat_value = section.settings.stat_value
  assign stat_footnote = section.settings.stat_footnote
  assign intro = section.settings.intro

  # Per-product pillars come from a product metafield (list of "pillar" metaobjects).
  # Each entry has: title, body, image. Falls back to nothing if unset.
  assign pillars = product.metafields.custom.pillars.value
-%}

<section class="product-pillars full-width">
  <div class="product-pillars__inner cham-container">

    {%- comment -%} ===== Big editorial stat claim ===== {%- endcomment -%}
    {%- if stat_value != blank -%}
      <div class="product-pillars__stat-block" data-reveal>
        <p class="product-pillars__stat font-display">{{ stat_value }}</p>
        {%- if stat_footnote != blank -%}
          <p class="product-pillars__stat-note">{{ stat_footnote }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} ===== Section heading + intro ===== {%- endcomment -%}
    <div class="product-pillars__head" data-reveal>
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="product-pillars__heading font-display">
        {{- section.settings.heading_lead -}}
        {%- if section.settings.heading_emphasis != blank %} <em>{{ section.settings.heading_emphasis }}</em>{%- endif -%}
      </h2>
      {%- if intro != blank -%}
        <p class="product-pillars__intro">{{ intro }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} ===== Pillar cards (per-product, from metafield) ===== {%- endcomment -%}
    {%- if pillars != blank and pillars.size > 0 -%}
      <div class="product-pillars__grid">
        {%- for pillar in pillars -%}
          {%- assign card_image = pillar.image -%}
          {%- assign card_title = pillar.title -%}
          {%- assign card_body = pillar.body -%}
          <article class="product-pillars__item" data-reveal data-reveal-delay="{{ forloop.index0 | times: 100 }}">
            <div class="product-pillars__media">
              {%- if card_image != blank -%}
                <img
                  src="{{ card_image | image_url: width: 900 }}"
                  srcset="{{ card_image | image_url: width: 450 }} 450w, {{ card_image | image_url: width: 900 }} 900w, {{ card_image | image_url: width: 1300 }} 1300w"
                  sizes="(min-width: 768px) 30vw, 100vw"
                  alt="{{ card_title | escape }}"
                  width="{{ card_image.width | default: 900 }}"
                  height="{{ card_image.height | default: 1125 }}"
                  class="product-pillars__img"
                  loading="lazy"
                  decoding="async"
                >
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'product-pillars__img product-pillars__img--placeholder' }}
              {%- endif -%}
            </div>
            {%- if card_title != blank -%}
              <h3 class="product-pillars__title">{{ card_title }}</h3>
            {%- endif -%}
            {%- if card_body != blank -%}
              <p class="product-pillars__body">{{ card_body }}</p>
            {%- endif -%}
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .product-pillars {
    background-color: var(--surface);
    padding-block: 6rem;
  }

  @media (min-width: 1024px) {
    .product-pillars {
      padding-block: 9rem;
    }
  }

  /* === Stat claim === */
  .product-pillars__stat-block {
    max-width: 48rem;
    margin-bottom: 3.5rem;
  }

  @media (min-width: 1024px) {
    .product-pillars__stat-block {
      margin-bottom: 4.5rem;
    }
  }

  .product-pillars__stat {
    font-size: clamp(1.875rem, 3.4vw, 3rem);
    font-weight: 300;
    line-height: 1.08;
    letter-spacing: -0.015em;
    text-wrap: balance;
  }

  .product-pillars__stat-note {
    margin-top: 1.25rem;
    font-size: 0.8125rem;
    color: var(--muted-foreground);
  }

  /* === Heading + intro === */
  .product-pillars__head {
    max-width: 60rem;
  }

  .product-pillars__heading {
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 300;
    line-height: 1.0;
    letter-spacing: -0.015em;
    margin-top: 1.25rem;
    text-transform: uppercase;
  }

  .product-pillars__heading em {
    color: var(--primary);
    font-style: italic;
    text-transform: none;
  }

  .product-pillars__intro {
    margin-top: 1.5rem;
    max-width: 32rem;
    color: color-mix(in oklab, var(--foreground) 70%, transparent);
    line-height: 1.7;
  }

  /* === Cards grid === */
  .product-pillars__grid {
    display: grid;
    grid-template-columns: 1fr;
    column-gap: 2rem;
    row-gap: 3.5rem;
    margin-top: 3.5rem;
  }

  @media (min-width: 768px) {
    .product-pillars__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .product-pillars__grid {
      margin-top: 4.5rem;
      column-gap: 2.5rem;
    }
  }

  .product-pillars__media {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background-color: color-mix(in oklab, var(--foreground) 6%, var(--surface));
  }

  .product-pillars__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-pillars__img--placeholder {
    color: color-mix(in oklab, var(--primary) 25%, var(--surface));
  }

  .product-pillars__title {
    margin-top: 1.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--foreground);
  }

  .product-pillars__body {
    margin-top: 0.875rem;
    color: color-mix(in oklab, var(--foreground) 75%, transparent);
    line-height: 1.7;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.product_pillars.name",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "The cards are per-product. Set them on each product under Metafields → Pillars (a list of Pillar entries, each with a title, body and image). The heading and stat below are shared across products."
    },
    {
      "type": "header",
      "content": "Stat claim"
    },
    {
      "type": "text",
      "id": "stat_value",
      "label": "Stat headline",
      "info": "Optional. Only use a result you can substantiate (e.g. your own consumer test). Leave blank to hide."
    },
    {
      "type": "text",
      "id": "stat_footnote",
      "label": "Stat footnote",
      "info": "e.g. the test method and sample size that backs the stat."
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Considered Formulation"
    },
    {
      "type": "text",
      "id": "heading_lead",
      "label": "t:labels.heading_lead",
      "default": "Built around what your skin"
    },
    {
      "type": "text",
      "id": "heading_emphasis",
      "label": "t:labels.heading_emphasis",
      "default": "actually responds to."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro paragraph"
    }
  ],
  "presets": [
    {
      "name": "t:sections.product_pillars.name"
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
