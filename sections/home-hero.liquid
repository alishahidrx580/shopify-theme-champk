      "unit": "px",
      "default": 640
    }
  ],
  "blocks": [
    {
      "type": "hero_image",
      "name": "Hero image (rotation)",
      "limit": 10,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image",
          "info": "Add multiple blocks to enable rotation. The section image above also joins the pool."
        },
        {
          "type": "range",
          "id": "position_x",
          "label": "Horizontal focal point",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 50,
          "info": "0 = far left, 50 = center, 100 = far right."
        },
        {
          "type": "range",
          "id": "position_y",
          "label": "Vertical focal point",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 50,
          "info": "0 = top, 50 = center, 100 = bottom. Lower this if the top of your 16:9 image is getting cut."
        }
