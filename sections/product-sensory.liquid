{%- liquid
  assign sensory_image = product.metafields.custom.sensory_image
  if sensory_image == blank and product.images.size > 0
    assign last_idx = product.images.size | minus: 1
    assign sensory_image = product.images[last_idx]
  endif

  assign texture = product.metafields.custom.sensory_texture
  assign finish = product.metafields.custom.sensory_finish
  assign tags = product.metafields.custom.sensory_tags.value
  assign media_position = section.settings.media_position | default: 'left'
-%}

<section class="product-sensory full-width product-sensory--media-{{ media_position }}">
  <div class="product-sensory__inner cham-container">
    <div class="product-sensory__grid">
      <div class="product-sensory__media-col" data-reveal>
        <div class="product-sensory__media">
          {%- if sensory_image != blank -%}
            <img
              src="{{ sensory_image | image_url: width: 1400 }}"
              srcset="{{ sensory_image | image_url: width: 700 }} 700w, {{ sensory_image | image_url: width: 1400 }} 1400w, {{ sensory_image | image_url: width: 2000 }} 2000w"
              sizes="(min-width: 1024px) 55vw, 100vw"
              alt="{{ product.title | append: ' sensory experience' | escape }}"
              width="{{ sensory_image.width | default: 1400 }}"
              height="{{ sensory_image.height | default: 1600 }}"
              loading="lazy"
              decoding="async"
              class="product-sensory__img"
            >
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'product-sensory__img product-sensory__img--placeholder' }}
          {%- endif -%}
        </div>
      </div>

      <div class="product-sensory__copy-col" data-reveal data-reveal-delay="120">
        <div class="product-sensory__copy-inner">
          {%- if section.settings.eyebrow != blank -%}
            <span class="eyebrow">{{ section.settings.eyebrow }}</span>
          {%- endif -%}
          <h2 class="product-sensory__heading font-display">
            {{- section.settings.heading_lead -}}
            {%- if section.settings.heading_emphasis != blank %} <em>{{ section.settings.heading_emphasis }}</em>{%- endif -%}
          </h2>

          {%- if texture != blank -%}
            <p class="product-sensory__line product-sensory__line--lead">{{ texture }}</p>
          {%- endif -%}
          {%- if finish != blank -%}
            <p class="product-sensory__line">{{ finish }}</p>
          {%- endif -%}

          {%- if section.settings.body != blank -%}
            <div class="product-sensory__body rte">{{ section.settings.body }}</div>
          {%- endif -%}

          {%- if tags != blank and tags.size > 0 -%}
            <ul class="product-sensory__chips">
              {%- for tag in tags -%}
                <li class="product-sensory__chip">{{ tag }}</li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  /* La Mer "Shake to Rejuvenate": contained split, tall portrait image one
     side, uppercase serif heading + copy the other, vertically centered. */
  .product-sensory {
    width: 100%;
    padding-block: 4.5rem;
  }

  @media (min-width: 1024px) {
    .product-sensory {
      padding-block: 7rem;
    }
  }

  .product-sensory__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .product-sensory__grid {
      grid-template-columns: 55% minmax(0, 1fr);
      column-gap: 4.5rem;
    }
    /* Flip sides without reordering the DOM (keeps reading order intact). */
    .product-sensory--media-right .product-sensory__grid {
      grid-template-columns: minmax(0, 1fr) 55%;
    }
    .product-sensory--media-right .product-sensory__media-col { order: 2; }
  }

  /* === Media === */
  .product-sensory__media {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background-color: var(--surface);
  }

  @media (min-width: 1024px) {
    .product-sensory__media {
      aspect-ratio: 3 / 4;
    }
  }

  .product-sensory__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-sensory__img--placeholder {
    color: color-mix(in oklab, var(--primary) 25%, var(--surface));
  }

  /* === Copy === */
  .product-sensory__copy-inner {
    max-width: 30rem;
  }

  @media (min-width: 1024px) {
    .product-sensory--media-right .product-sensory__copy-inner {
      margin-left: auto;
    }
  }

  .product-sensory__heading {
    margin-top: 1.5rem;
    font-size: clamp(2.5rem, 4.75vw, 4.25rem);
    font-weight: 300;
    line-height: 1.0;
    letter-spacing: -0.015em;
    text-transform: uppercase;
  }

  .product-sensory__heading em {
    color: var(--primary);
    font-style: italic;
    text-transform: none;
  }

  .product-sensory__line {
    margin-top: 1.25rem;
    font-size: 1rem;
    line-height: 1.65;
    color: color-mix(in oklab, var(--foreground) 75%, transparent);
  }

  /* First line reads as the lead claim — slightly larger and darker. */
  .product-sensory__line--lead {
    margin-top: 2rem;
    font-size: 1.125rem;
    color: color-mix(in oklab, var(--foreground) 92%, transparent);
  }

  .product-sensory__line--lead + .product-sensory__line {
    margin-top: 0.875rem;
  }

  .product-sensory__body {
    margin-top: 1.5rem;
    max-width: 32rem;
    color: var(--muted-foreground);
    line-height: 1.7;
    font-size: 0.9375rem;
  }

  .product-sensory__body > p { margin: 0; }
  .product-sensory__body > p + p { margin-top: 1rem; }

  .product-sensory__chips {
    margin: 2.5rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  .product-sensory__chip {
    padding: 0.625rem 1rem;
    border: 1px solid color-mix(in oklab, var(--primary) 38%, transparent);
    color: var(--primary);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .product-sensory__chip:hover {
    background-color: color-mix(in oklab, var(--primary) 8%, transparent);
    border-color: color-mix(in oklab, var(--primary) 60%, transparent);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.product_sensory.name",
  "tag": "section",
  "settings": [
    {
      "type": "select",
      "id": "media_position",
      "label": "Media position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "The Sensory Experience"
    },
    {
      "type": "text",
      "id": "heading_lead",
      "label": "t:labels.heading_lead",
      "default": "How it"
    },
    {
      "type": "text",
      "id": "heading_emphasis",
      "label": "t:labels.heading_emphasis",
      "default": "feels."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "info": "Optional. A short paragraph on the overall experience of using the serum."
    }
  ],
  "presets": [
    {
      "name": "t:sections.product_sensory.name"
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
