{%- liquid
  # Build the hero image pool: section image + non-blank blocks.
  # Rotation happens client-side at a configurable interval, with Ken Burns
  # (slow zoom + gentle pan) motion on every slide for a cinematic feel.

  assign rotation_seconds = section.settings.rotation_seconds | default: 6
  assign fade_ms = section.settings.fade_ms | default: 800

  # Ken Burns preset resolution.
  # Each preset defines: zoom_from, zoom_to, duration_s.
  assign kb_preset = section.settings.kb_preset | default: 'whisper'

  if kb_preset == 'whisper'
    assign kb_zoom_from = 1.00
    assign kb_zoom_to = 1.06
    assign kb_duration_s = 18
  elsif kb_preset == 'editorial'
    assign kb_zoom_from = 1.00
    assign kb_zoom_to = 1.10
    assign kb_duration_s = 14
  elsif kb_preset == 'cinematic'
    assign kb_zoom_from = 1.00
    assign kb_zoom_to = 1.18
    assign kb_duration_s = 11
  elsif kb_preset == 'lively'
    assign kb_zoom_from = 1.00
    assign kb_zoom_to = 1.25
    assign kb_duration_s = 9
  elsif kb_preset == 'custom'
    assign kb_zoom_from = 1.00
    assign kb_zoom_to_raw = section.settings.kb_zoom_to | default: 110
    assign kb_zoom_to = kb_zoom_to_raw | times: 1.0 | divided_by: 100.0
    assign kb_duration_s = section.settings.kb_duration_s | default: 14
  elsif kb_preset == 'off'
    assign kb_zoom_from = 1.00
    assign kb_zoom_to = 1.00
    assign kb_duration_s = 1
  else
    assign kb_zoom_from = 1.00
    assign kb_zoom_to = 1.06
    assign kb_duration_s = 18
  endif

  # Determine first/initial image for SSR (LCP-friendly).
  assign initial_image = section.settings.image
  assign initial_pos_x = section.settings.position_x | default: 50
  assign initial_pos_y = section.settings.position_y | default: 50

  if initial_image == blank
    for block in section.blocks
      if block.settings.image != blank
        assign initial_image = block.settings.image
        assign initial_pos_x = block.settings.position_x | default: 50
        assign initial_pos_y = block.settings.position_y | default: 50
        break
      endif
    endfor
  endif
-%}

<section
  class="home-hero full-width{% if kb_preset == 'off' %} home-hero--no-motion{% endif %}"
  style="
    --min-height-svh: {{ section.settings.min_height_svh }}svh;
    --min-height-px: {{ section.settings.min_height_px }}px;
    --kb-zoom-from: {{ kb_zoom_from }};
    --kb-zoom-to: {{ kb_zoom_to }};
    --kb-duration: {{ kb_duration_s }}s;
  "
  data-rotation-ms="{{ rotation_seconds | times: 1000 }}"
  data-fade-ms="{{ fade_ms }}"
>
  <div class="home-hero__media" aria-hidden="true">
    {%- if initial_image != blank -%}
      {%- # First slide: eager-loaded for LCP. data-kb-dir cycles 0–3 to vary pan direction. -%}
      <img
        src="{{ initial_image | image_url: width: 1920 }}"
        srcset="{{ initial_image | image_url: width: 800 }} 800w, {{ initial_image | image_url: width: 1280 }} 1280w, {{ initial_image | image_url: width: 1920 }} 1920w, {{ initial_image | image_url: width: 2560 }} 2560w"
        sizes="100vw"
        alt="{{ initial_image.alt | default: 'general.brand.name' | t | escape }}"
        width="{{ initial_image.width }}"
        height="{{ initial_image.height }}"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="home-hero__image is-active"
        style="object-position: {{ initial_pos_x }}% {{ initial_pos_y }}%;"
        data-slide="0"
        data-kb-dir="0"
      >

      {%- assign slide_index = 1 -%}

      {%- if section.settings.image != blank -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.image != blank -%}
            {%- assign bx = block.settings.position_x | default: 50 -%}
            {%- assign by = block.settings.position_y | default: 50 -%}
            {%- assign kb_dir = slide_index | modulo: 4 -%}
            <img
              src="{{ block.settings.image | image_url: width: 1920 }}"
              srcset="{{ block.settings.image | image_url: width: 800 }} 800w, {{ block.settings.image | image_url: width: 1280 }} 1280w, {{ block.settings.image | image_url: width: 1920 }} 1920w, {{ block.settings.image | image_url: width: 2560 }} 2560w"
              sizes="100vw"
              alt="{{ block.settings.image.alt | default: 'general.brand.name' | t | escape }}"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
              loading="lazy"
              decoding="async"
              class="home-hero__image"
              style="object-position: {{ bx }}% {{ by }}%;"
              data-slide="{{ slide_index }}"
              data-kb-dir="{{ kb_dir }}"
            >
            {%- assign slide_index = slide_index | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- assign first_block_used = false -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.image != blank -%}
            {%- if first_block_used == false -%}
              {%- assign first_block_used = true -%}
            {%- else -%}
              {%- assign bx = block.settings.position_x | default: 50 -%}
              {%- assign by = block.settings.position_y | default: 50 -%}
              {%- assign kb_dir = slide_index | modulo: 4 -%}
              <img
                src="{{ block.settings.image | image_url: width: 1920 }}"
                srcset="{{ block.settings.image | image_url: width: 800 }} 800w, {{ block.settings.image | image_url: width: 1280 }} 1280w, {{ block.settings.image | image_url: width: 1920 }} 1920w, {{ block.settings.image | image_url: width: 2560 }} 2560w"
                sizes="100vw"
                alt="{{ block.settings.image.alt | default: 'general.brand.name' | t | escape }}"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                loading="lazy"
                decoding="async"
                class="home-hero__image"
                style="object-position: {{ bx }}% {{ by }}%;"
                data-slide="{{ slide_index }}"
                data-kb-dir="{{ kb_dir }}"
              >
              {%- assign slide_index = slide_index | plus: 1 -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    {%- else -%}
      <div class="home-hero__image home-hero__image--placeholder is-active" aria-hidden="true"></div>
    {%- endif -%}
  </div>

  <div class="home-hero__overlay" aria-hidden="true"></div>

  <div class="home-hero__inner">
    <div class="home-hero__content" data-reveal>
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow home-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h1 class="home-hero__heading font-display">
        {{- section.settings.heading_lead -}}
        {%- if section.settings.heading_break -%}<br>{%- endif -%}
        {%- if section.settings.heading_emphasis != blank -%}
          {%- unless section.settings.heading_break %} {% endunless -%}
          <em>{{ section.settings.heading_emphasis }}</em>
        {%- endif -%}
      </h1>

      {%- if section.settings.body != blank -%}
        <div class="home-hero__body">{{ section.settings.body }}</div>
      {%- endif -%}

      {%- if section.settings.cta_primary_label != blank or section.settings.cta_secondary_label != blank -%}
        <div class="home-hero__ctas">
          {%- if section.settings.cta_primary_label != blank -%}
            <a href="{{ section.settings.cta_primary_url | default: '#' }}" class="home-hero__cta-primary">
              {{ section.settings.cta_primary_label }}
            </a>
          {%- endif -%}
          {%- if section.settings.cta_secondary_label != blank -%}
            <a href="{{ section.settings.cta_secondary_url | default: '#' }}" class="home-hero__cta-secondary gold-link">
              {{ section.settings.cta_secondary_label }} →
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .home-hero {
    position: relative;
    height: var(--min-height-svh, 100svh);
    min-height: var(--min-height-px, 640px);
    width: 100%;
    overflow: hidden;
  }

  .home-hero__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .home-hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 50%;
    opacity: 0;
    transition: opacity var(--hero-fade-ms, 800ms) ease-in-out;
    transform-origin: 50% 50%;
    will-change: opacity, transform;
  }

  .home-hero__image.is-active {
    opacity: 1;
    /* Transform is driven by JS for a continuous zoom flow across slides.
       No CSS animation here — JS sets transform on every frame. */
  }

  /* Pan direction varies by slide so consecutive images don't feel identical.
     Each direction uses a different transform-origin to shift the zoom focus. */
  .home-hero__image[data-kb-dir="0"] { transform-origin: 70% 30%; } /* zooms toward top-right */
  .home-hero__image[data-kb-dir="1"] { transform-origin: 30% 70%; } /* zooms toward bottom-left */
  .home-hero__image[data-kb-dir="2"] { transform-origin: 30% 30%; } /* zooms toward top-left */
  .home-hero__image[data-kb-dir="3"] { transform-origin: 70% 70%; } /* zooms toward bottom-right */

  .home-hero--no-motion .home-hero__image.is-active {
    transform: scale(1.02) !important;
  }

  .home-hero__image--placeholder {
    background: linear-gradient(135deg, oklch(0.25 0.02 70), oklch(0.15 0.01 60));
    opacity: 1;
  }

  .home-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgb(0 0 0 / 1), rgb(0 0 0 / 0.4) 50%, rgb(0 0 0 / 0.6));
    z-index: 1;
  }

  .home-hero__inner {
    position: relative;
    z-index: 2;
    height: 100%;
    max-width: var(--page-max-width);
    margin-inline: auto;
    padding-inline: var(--page-padding-inline);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: 5rem;
  }

  @media (min-width: 1024px) {
    .home-hero__inner {
      padding-inline: var(--page-padding-inline-lg);
      padding-bottom: 7rem;
    }
  }

  .home-hero__eyebrow {
    color: var(--primary-glow);
    margin-bottom: 1.5rem;
  }

  .home-hero__eyebrow::before {
    display: none;
  }

  .home-hero__heading {
    font-size: clamp(3.05rem, 9vw, 7.5rem);
    line-height: 0.95;
    color: #fff;
    max-width: 64rem;
    margin: 0;
  }

  .home-hero__heading em {
    color: var(--primary-glow);
    font-style: italic;
  }

  .home-hero__body {
    margin-top: 2rem;
    max-width: 28rem;
    font-size: 1rem;
    color: rgb(255 255 255 / 0.85);
    line-height: 1.65;
  }

  @media (min-width: 1024px) {
    .home-hero__body {
      font-size: 1.125rem;
    }
  }

  .home-hero__body > p {
    margin: 0;
  }

  .home-hero__ctas {
    margin-top: 2.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.25rem;
  }

  .home-hero__cta-primary {
    display: inline-block;
    padding: 1rem 2.25rem;
    background-color: var(--primary);
    color: var(--primary-foreground);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.75rem;
    font-weight: 500;
    transition: background-color 0.3s ease;
  }

  .home-hero__cta-primary:hover,
  .home-hero__cta-primary:focus-visible {
    background-color: var(--primary-glow);
  }

  .home-hero__cta-secondary {
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.75rem;
    color: rgb(255 255 255 / 0.9);
    transition: color 0.3s ease;
  }

  .home-hero__cta-secondary:hover,
  .home-hero__cta-secondary:focus-visible {
    color: var(--primary-glow);
  }

  @media (max-height: 900px) and (min-width: 768px) {
    .home-hero__inner {
      padding-top: calc(var(--header-height, 4.5rem) + 0.75rem);
      padding-bottom: 3rem;
    }

    .home-hero__eyebrow {
      margin-bottom: 0.75rem;
    }

    .home-hero__heading {
      font-size: clamp(2.5rem, 7vh, 5rem);
    }

    .home-hero__body {
      margin-top: 1rem;
    }

    .home-hero__ctas {
      margin-top: 1.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .home-hero__image {
      transition: none;
      animation: none !important;
      transform: scale(1.02) !important;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    const heroes = Array.from(document.querySelectorAll('.home-hero'));

    heroes.forEach((root) => {
      const slides = Array.from(root.querySelectorAll('.home-hero__image'));
      if (slides.length === 0) return;

      const rotationMs = parseInt(root.dataset.rotationMs, 10) || 6000;
      const fadeMs = parseInt(root.dataset.fadeMs, 10) || 800;

      // Apply fade duration to each slide.
      slides.forEach((s) => s.style.setProperty('--hero-fade-ms', fadeMs + 'ms'));

      // Read zoom range from CSS custom properties set in Liquid.
      const cs = window.getComputedStyle(root);
      const zoomFrom = parseFloat(cs.getPropertyValue('--kb-zoom-from')) || 1.0;
      const zoomTo = parseFloat(cs.getPropertyValue('--kb-zoom-to')) || 1.06;

      // If motion is effectively off (zoom range is zero), just set static.
      const motionOff = root.classList.contains('home-hero--no-motion') || Math.abs(zoomTo - zoomFrom) < 0.001;
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (motionOff || reducedMotion) {
        slides.forEach((s, i) => {
          s.style.transform = 'scale(1.02)';
          if (i === 0) s.classList.add('is-active');
        });
        // Still rotate if multiple slides, just without zoom.
        if (slides.length <= 1) return;
        let current = 0;
        const tick = () => {
          const next = (current + 1) % slides.length;
          slides[current].classList.remove('is-active');
          slides[next].classList.add('is-active');
          current = next;
        };
        const t = window.setInterval(tick, rotationMs);
        document.addEventListener('visibilitychange', () => {
          if (document.hidden) window.clearInterval(t);
        });
        return;
      }

      // ===== Continuous zoom across slides =====
      // A single shared `zoom` value oscillates between zoomFrom and zoomTo.
      // Direction reverses on each slide change so the next slide picks up
      // exactly where the previous left off, then heads back the other way.
      //
      // - direction = +1: zooming IN  (toward zoomTo)
      // - direction = -1: zooming OUT (toward zoomFrom)
      //
      // Speed is chosen so that one full traversal (zoomFrom -> zoomTo or vice
      // versa) takes `rotationMs` — meaning each slide does exactly one half
      // of a zoom cycle while it's visible. This guarantees the handoff
      // happens cleanly at the extremes.

      let current = 0;
      let zoom = zoomFrom;
      let direction = 1; // start by zooming in
      let lastTs = null;
      let rafId = null;
      let timer = null;

      // Initialize: first slide visible, all set to starting zoom.
      slides.forEach((s, i) => {
        s.style.transform = 'scale(' + zoomFrom + ')';
        if (i === 0) s.classList.add('is-active');
      });

      function applyTransformToAll() {
        // Apply the current zoom to every slide so the outgoing slide stays
        // at the same scale during the crossfade (no snap), and the incoming
        // slide is already at the matching scale before it fades in.
        const t = 'scale(' + zoom.toFixed(4) + ')';
        for (let i = 0; i < slides.length; i++) {
          slides[i].style.transform = t;
        }
      }

      function frame(ts) {
        if (lastTs === null) lastTs = ts;
        const dt = ts - lastTs;
        lastTs = ts;

        // Travel one full (zoomFrom <-> zoomTo) range every rotationMs.
        const range = zoomTo - zoomFrom;
        const speed = range / rotationMs; // per ms
        zoom += direction * speed * dt;

        // Clamp at the extremes (the rotation tick handles direction flip,
        // but this guards against drift if a tick is delayed).
        if (zoom > zoomTo) zoom = zoomTo;
        if (zoom < zoomFrom) zoom = zoomFrom;

        applyTransformToAll();
        rafId = window.requestAnimationFrame(frame);
      }

      function showNext() {
        const next = (current + 1) % slides.length;
        if (next === current) return;

        // Crossfade: outgoing fades out, incoming fades in.
        slides[current].classList.remove('is-active');
        slides[next].classList.add('is-active');

        // Reverse zoom direction so the new slide heads back the other way.
        direction *= -1;
        current = next;
      }

      function startLoop() {
        if (rafId === null) {
          lastTs = null;
          rafId = window.requestAnimationFrame(frame);
        }
        if (timer === null && slides.length > 1) {
          timer = window.setInterval(showNext, rotationMs);
        }
      }

      function stopLoop() {
        if (rafId !== null) {
          window.cancelAnimationFrame(rafId);
          rafId = null;
        }
        if (timer !== null) {
          window.clearInterval(timer);
          timer = null;
        }
      }

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          stopLoop();
        } else {
          startLoop();
        }
      });

      startLoop();
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.home_hero.name",
  "tag": "section",
  "class": "home-hero-wrapper",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image",
      "info": "Recommended: 1920×1280 or 16:9. Use the focal point sliders below to adjust which part stays visible."
    },
    {
      "type": "range",
      "id": "position_x",
      "label": "Main image — horizontal focal point",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50,
      "info": "0 = far left, 50 = center, 100 = far right."
    },
    {
      "type": "range",
      "id": "position_y",
      "label": "Main image — vertical focal point",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50,
      "info": "0 = top, 50 = center, 100 = bottom. Lower this if the top of your 16:9 image is getting cut."
    },
    {
      "type": "header",
      "content": "Rotation"
    },
    {
      "type": "range",
      "id": "rotation_seconds",
      "label": "Seconds between image changes",
      "min": 2,
      "max": 30,
      "step": 1,
      "unit": "s",
      "default": 6
    },
    {
      "type": "range",
      "id": "fade_ms",
      "label": "Fade duration (ms)",
      "min": 200,
      "max": 2000,
      "step": 50,
      "unit": "ms",
      "default": 800
    },
    {
      "type": "header",
      "content": "Motion (Ken Burns)"
    },
    {
      "type": "select",
      "id": "kb_preset",
      "label": "Motion preset",
      "options": [
        { "value": "whisper",   "label": "Whisper — barely there (recommended for luxury)" },
        { "value": "editorial", "label": "Editorial — tasteful, magazine-like" },
        { "value": "cinematic", "label": "Cinematic — bold, dramatic" },
        { "value": "lively",    "label": "Lively — energetic, modern" },
        { "value": "custom",    "label": "Custom — use sliders below" },
        { "value": "off",       "label": "Off — no motion" }
      ],
      "default": "whisper",
      "info": "Whisper: 1.00→1.06 over 18s · Editorial: 1.00→1.10 over 14s · Cinematic: 1.00→1.18 over 11s · Lively: 1.00→1.25 over 9s."
    },
    {
      "type": "range",
      "id": "kb_zoom_to",
      "label": "Custom — max zoom",
      "min": 102,
      "max": 140,
      "step": 1,
      "unit": "%",
      "default": 110,
      "info": "Only used when preset is set to 'Custom'. 102 = 1.02× zoom, 140 = 1.40× zoom."
    },
    {
      "type": "range",
      "id": "kb_duration_s",
      "label": "Custom — zoom duration",
      "min": 5,
      "max": 30,
      "step": 1,
      "unit": "s",
      "default": 14,
      "info": "Only used when preset is set to 'Custom'. Tip: keep this longer than the rotation interval for the smoothest feel."
    },
    {
      "type": "header",
      "content": "t:general.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Developed with French Formulation Standards"
    },
    {
      "type": "text",
      "id": "heading_lead",
      "label": "t:labels.heading_lead",
      "default": "Intelligent Skincare."
    },
    {
      "type": "checkbox",
      "id": "heading_break",
      "label": "t:labels.heading_break",
      "default": true
    },
    {
      "type": "text",
      "id": "heading_emphasis",
      "label": "t:labels.heading_emphasis",
      "default": "Radiance revealed."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "t:labels.body",
      "default": "<p>Precisely formulated to help your skin look calm, soft, and naturally radiant.</p>"
    },
    {
      "type": "header",
      "content": "t:labels.cta_label"
    },
    {
