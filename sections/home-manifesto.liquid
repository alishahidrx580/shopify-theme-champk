{%- liquid
  assign img = section.settings.image
  assign raw_video = section.settings.video_url
  assign video_src = ''
  if raw_video != blank
    assign url_prefix = raw_video | slice: 0, 4
    if url_prefix == 'http'
      assign video_src = raw_video
    else
      assign url_parts = raw_video | split: '/'
      assign filename = url_parts | last
      assign video_src = filename | file_url
    endif
  endif
  assign media_position = section.settings.media_position | default: 'right'
  assign show_rule = section.settings.show_rule
  assign focal = section.settings.focal_x | append: '% ' | append: section.settings.focal_y | append: '%'
  assign has_media = false
  if img != blank or video_src != blank
    assign has_media = true
  endif
-%}

<section class="home-manifesto home-manifesto--media-{{ media_position }} full-width">
  <div class="home-manifesto__inner cham-container">
    <div class="home-manifesto__grid">
      <div class="home-manifesto__text-col" data-reveal>
        {%- if section.settings.eyebrow != blank -%}
          <span class="home-manifesto__eyebrow">
            {%- if show_rule -%}<span class="home-manifesto__rule" aria-hidden="true"></span>{%- endif -%}
            <span class="eyebrow">{{ section.settings.eyebrow }}</span>
          </span>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="home-manifesto__heading font-display">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.body != blank -%}
          <div class="home-manifesto__body">{{ section.settings.body }}</div>
        {%- endif -%}

        {%- if section.settings.signature != blank -%}
          <div class="home-manifesto__signature">
            <span class="home-manifesto__signature-rule" aria-hidden="true"></span>
            <span class="home-manifesto__signature-text">{{ section.settings.signature }}</span>
          </div>
        {%- endif -%}

        {%- if section.settings.show_ornament -%}
          <div class="home-manifesto__ornament" aria-hidden="true">
            <svg viewBox="0 0 120 24" xmlns="http://www.w3.org/2000/svg" fill="none">
              <line x1="0" y1="12" x2="48" y2="12" stroke="currentColor" stroke-width="0.5" />
              <circle cx="60" cy="12" r="3" stroke="currentColor" stroke-width="0.5" fill="none" />
              <circle cx="60" cy="12" r="1" fill="currentColor" />
              <line x1="72" y1="12" x2="120" y2="12" stroke="currentColor" stroke-width="0.5" />
            </svg>
          </div>
        {%- endif -%}
      </div>

      {%- if has_media -%}
        <div class="home-manifesto__media-col" data-reveal data-reveal-delay="120">
          <div
            class="home-manifesto__media"
            style="--aspect-mobile: {{ section.settings.aspect_mobile }}; --aspect-desktop: {{ section.settings.aspect_desktop }};"
          >
            {%- if video_src != blank -%}
              <video
                class="home-manifesto__media-el"
                data-manifesto-video
                src="{{ video_src }}"
                {% if img != blank %}poster="{{ img | image_url: width: 1200 }}"{% endif %}
                muted
                loop
                playsinline
                autoplay
                preload="metadata"
              ></video>
            {%- elsif img != blank -%}
              <img
                class="home-manifesto__media-el"
                src="{{ img | image_url: width: 1400 }}"
                srcset="{{ img | image_url: width: 600 }} 600w, {{ img | image_url: width: 900 }} 900w, {{ img | image_url: width: 1400 }} 1400w"
                sizes="(min-width: 1024px) 45vw, 100vw"
                alt="{{ img.alt | escape }}"
                width="{{ img.width }}"
                height="{{ img.height }}"
                loading="lazy"
                decoding="async"
                style="object-position: {{ focal }};"
              >
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .home-manifesto {
    padding-block: 5rem;
  }

  @media (min-width: 768px) {
    .home-manifesto {
      padding-block: 7rem;
    }
  }

  @media (min-width: 1024px) {
    .home-manifesto {
      padding-block: 10rem;
    }
  }

  /* Grid: stacked on mobile, two columns on desktop */
  .home-manifesto__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 1024px) {
    .home-manifesto__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 5rem;
      align-items: center;
    }
    .home-manifesto--media-right .home-manifesto__text-col { order: 1; }
    .home-manifesto--media-right .home-manifesto__media-col { order: 2; }
    .home-manifesto--media-left .home-manifesto__text-col { order: 2; }
    .home-manifesto--media-left .home-manifesto__media-col { order: 1; }
  }

  /* Eyebrow with gold leading rule */
  .home-manifesto__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.75rem;
  }

  .home-manifesto__rule {
    display: inline-block;
    width: 2.5rem;
    height: 1px;
    background-color: var(--primary);
    flex: none;
  }

  /* Headline */
  .home-manifesto__heading {
    font-size: clamp(2rem, 8vw, 2.75rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--foreground);
    margin: 0;
    text-wrap: balance;
  }

  @media (min-width: 768px) {
    .home-manifesto__heading {
      font-size: clamp(2.5rem, 6vw, 3.75rem);
      line-height: 1.05;
    }
  }

  @media (min-width: 1024px) {
    .home-manifesto__heading {
      font-size: clamp(2.75rem, 4vw, 3.75rem);
      line-height: 1.02;
    }
  }

  .home-manifesto__heading em {
    color: var(--primary);
    font-style: italic;
  }

  .home-manifesto__heading p { margin: 0; }

  /* Body */
  .home-manifesto__body {
    margin-top: 2rem;
    font-size: 1rem;
    line-height: 1.75;
    color: color-mix(in oklab, var(--foreground) 75%, transparent);
    max-width: 46ch;
    text-wrap: pretty;
  }

  @media (min-width: 768px) {
    .home-manifesto__body {
      font-size: 1.0625rem;
      line-height: 1.8;
    }
  }

  .home-manifesto__body > p { margin: 0; }
  .home-manifesto__body > p + p { margin-top: 1rem; }

  /* Signature */
  .home-manifesto__signature {
    margin-top: 2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .home-manifesto__signature-rule {
    flex: 0 0 2.5rem;
    height: 1px;
    background-color: var(--primary);
  }

  .home-manifesto__signature-text {
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--primary);
    font-weight: 500;
  }

  /* Ornament */
  .home-manifesto__ornament {
    margin-top: 3rem;
    display: flex;
    color: var(--primary);
    opacity: 0.7;
  }

  .home-manifesto__ornament svg {
    width: 7.5rem;
    height: 1.5rem;
  }

  /* Media */
  .home-manifesto__media {
    position: relative;
    width: 100%;
    aspect-ratio: var(--aspect-mobile, 4 / 5);
    overflow: hidden;
    background-color: var(--surface);
  }

  @media (min-width: 1024px) {
    .home-manifesto__media {
      aspect-ratio: var(--aspect-desktop, 3 / 4);
    }
  }

  .home-manifesto__media-el {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    document.querySelectorAll('[data-manifesto-video]').forEach(function (v) {
      v.removeAttribute('autoplay');
      try { v.pause(); } catch (e) {}
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.home_manifesto.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "About Cham"
    },
    {
      "type": "checkbox",
      "id": "show_rule",
      "label": "Show eyebrow rule",
      "default": true
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "t:sections.home_manifesto.heading_label",
      "info": "Short headline phrase only. Use <em> for the italic gold emphasis.",
      "default": "<p>Crafted for <em>natural radiance.</em></p>"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Supporting body copy",
      "info": "The full manifesto paragraph — appears smaller and softer next to the headline.",
      "default": "<p>Each Cham formulation is designed to complement your skin's natural rhythm, so it looks softer, calmer, and naturally luminous.</p><p>We work with restraint, choosing ingredients for what they do — not how they perform on a label.</p>"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video (optional)",
      "info": "Filename of a video in Settings → Files (e.g. atelier.mp4) or a full https URL. Plays muted and looped, with the image as its poster. Overrides the image when set."
    },
    {
      "type": "select",
      "id": "media_position",
      "label": "Media position (desktop)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "right"
    },
    {
      "type": "select",
      "id": "aspect_desktop",
      "label": "Media aspect (desktop)",
      "options": [
        { "value": "3 / 4", "label": "3:4 (portrait)" },
        { "value": "4 / 5", "label": "4:5 (portrait)" },
        { "value": "1 / 1", "label": "Square" },
        { "value": "4 / 3", "label": "4:3 (landscape)" }
      ],
      "default": "3 / 4"
    },
    {
      "type": "select",
      "id": "aspect_mobile",
      "label": "Media aspect (mobile)",
      "options": [
        { "value": "4 / 5", "label": "4:5 (portrait)" },
        { "value": "3 / 4", "label": "3:4 (portrait)" },
        { "value": "1 / 1", "label": "Square" },
        { "value": "16 / 9", "label": "16:9 (landscape)" }
      ],
      "default": "4 / 5"
    },
    {
      "type": "range",
      "id": "focal_x",
      "label": "Image focal — horizontal",
      "min": 0, "max": 100, "step": 5, "unit": "%", "default": 50
    },
    {
      "type": "range",
      "id": "focal_y",
      "label": "Image focal — vertical",
      "min": 0, "max": 100, "step": 5, "unit": "%", "default": 50
    },
    {
      "type": "header",
      "content": "Signature"
    },
    {
      "type": "text",
      "id": "signature",
      "label": "Signature line",
      "info": "Optional. e.g. 'The Cham Atelier' or a founder name.",
      "default": "The Cham Atelier"
    },
    {
      "type": "header",
      "content": "Ornament"
    },
    {
      "type": "checkbox",
      "id": "show_ornament",
      "label": "Show decorative ornament",
      "info": "A small rule-line with a gold dot, placed below the manifesto copy.",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "t:sections.home_manifesto.presets_default"
    }
  ]
}
{% endschema %}
