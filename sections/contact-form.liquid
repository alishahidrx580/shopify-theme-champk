      "id": "first_name_label",
      "label": "First name label",
      "default": "First name"
    },
    {
      "type": "text",
      "id": "last_name_label",
      "label": "Last name label",
      "default": "Last name"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email label",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "subject_label",
      "label": "Subject label",
      "default": "Subject"
    },
    {
      "type": "text",
      "id": "message_label",
      "label": "Message label",
      "default": "Message"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit button label",
      "default": "Send Message"
    },
