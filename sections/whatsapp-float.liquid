{%- liquid
  # Resolve the chat destination. A custom link wins; otherwise build a
  # wa.me link from the phone number (digits only) plus an optional message.
  assign wa_phone = section.settings.phone | remove: ' ' | remove: '+' | remove: '-' | remove: '(' | remove: ')' | remove: '.'
  assign wa_href = ''

  if section.settings.custom_url != blank
    assign wa_href = section.settings.custom_url
  elsif wa_phone != blank
    assign wa_href = 'https://wa.me/' | append: wa_phone
    if section.settings.prefilled_message != blank
      assign wa_text = section.settings.prefilled_message | url_encode
      assign wa_href = wa_href | append: '?text=' | append: wa_text
    endif
  endif

  assign wa_label = section.settings.tooltip
  if wa_label == blank
    assign wa_label = 'sections.whatsapp_float.default_label' | t
  endif
-%}

{%- if section.settings.enabled and wa_href != blank -%}
  <a
    class="whatsapp-float whatsapp-float--{{ section.settings.color_style }}"
    href="{{ wa_href }}"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="{{ wa_label | escape }}"
    title="{{ wa_label | escape }}"
  >
    <svg class="whatsapp-float__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.149-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
    </svg>
    {%- if section.settings.show_badge and section.settings.badge_text != blank -%}
      <span class="whatsapp-float__badge" aria-hidden="true">{{ section.settings.badge_text }}</span>
    {%- endif -%}
  </a>
{%- endif -%}

{% stylesheet %}
  .whatsapp-float {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 40;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 9999px;
    color: var(--whatsapp-fg);
    background-color: var(--whatsapp-bg);
    box-shadow: 0 12px 30px -8px color-mix(in oklab, var(--whatsapp-bg) 55%, transparent);
    transition: transform 0.3s ease, background-color 0.3s ease, opacity 0.3s ease;
  }

  @media (min-width: 1024px) {
    .whatsapp-float {
      right: 2rem;
      bottom: 2rem;
      width: 3.75rem;
      height: 3.75rem;
    }
  }

  /* Theme gold — mirrors the primary action treatment used site-wide. */
  .whatsapp-float--gold {
    --whatsapp-bg: var(--primary);
    --whatsapp-fg: var(--primary-foreground);
  }

  .whatsapp-float--gold:hover,
  .whatsapp-float--gold:focus-visible {
    --whatsapp-bg: var(--primary-glow);
  }

  /* Classic WhatsApp green, for stores that prefer the familiar brand cue. */
  .whatsapp-float--green {
    --whatsapp-bg: #25d366;
    --whatsapp-fg: #ffffff;
  }

  .whatsapp-float--green:hover,
  .whatsapp-float--green:focus-visible {
    --whatsapp-bg: #1ebe5d;
  }

  .whatsapp-float:hover,
  .whatsapp-float:focus-visible {
    transform: translateY(-2px) scale(1.04);
  }

  .whatsapp-float:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 3px;
  }

  .whatsapp-float__icon {
    width: 1.75rem;
    height: 1.75rem;
  }

  /* Attention badge — pinned to the top-right, ringed in the page colour
     so it reads as a distinct chip the way a notification count would. */
  .whatsapp-float__badge {
    position: absolute;
    top: -0.125rem;
    right: -0.125rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.25rem;
    height: 1.25rem;
    padding: 0 0.3125rem;
    border-radius: 9999px;
    border: 2px solid var(--background);
    background-color: var(--destructive);
    color: var(--destructive-foreground);
    font-size: 0.6875rem;
    font-weight: 600;
    line-height: 1;
  }

  /* Step aside while the cart drawer (or any drawer) owns the screen. */
  html:has([data-drawer-open="true"]) .whatsapp-float {
    opacity: 0;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .whatsapp-float {
      transition: opacity 0.3s ease;
    }
    .whatsapp-float:hover,
    .whatsapp-float:focus-visible {
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.whatsapp_float.name",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "t:labels.whatsapp_enabled",
      "default": true
    },
    {
      "type": "text",
      "id": "phone",
      "label": "t:labels.whatsapp_number",
      "info": "t:labels.whatsapp_number_info",
      "placeholder": "919876543210"
    },
    {
      "type": "text",
      "id": "custom_url",
      "label": "t:labels.whatsapp_custom_url",
      "info": "t:labels.whatsapp_custom_url_info"
    },
    {
      "type": "text",
      "id": "prefilled_message",
      "label": "t:labels.whatsapp_prefilled_message",
      "info": "t:labels.whatsapp_prefilled_message_info",
      "default": "Hi! I'd like to know more about Cham skincare."
    },
    {
      "type": "text",
      "id": "tooltip",
      "label": "t:labels.whatsapp_tooltip",
      "default": "Chat with us on WhatsApp"
    },
    {
      "type": "select",
      "id": "color_style",
      "label": "t:labels.whatsapp_color_style",
      "options": [
        { "value": "gold", "label": "t:options.whatsapp_color.gold" },
        { "value": "green", "label": "t:options.whatsapp_color.green" }
      ],
      "default": "gold"
    },
    {
      "type": "header",
      "content": "Notification badge"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "t:labels.whatsapp_show_badge",
      "default": false
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "t:labels.whatsapp_badge_text",
      "info": "t:labels.whatsapp_badge_text_info",
      "default": "1"
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  }
}
{% endschema %}
