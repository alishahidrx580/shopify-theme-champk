{%- liquid
  assign words = article.content | strip_html | split: ' ' | size
  assign minutes = words | divided_by: 200
  if minutes < 1
    assign minutes = 1
  endif
  assign read_time = 'sections.main_blog.read_time_html' | t: minutes: minutes
  assign date_str = article.published_at | date: '%B %-d, %Y'
  assign back_label = 'sections.main_article.back_to_blog' | t: blog: blog.title
-%}

<article class="main-article full-width">
  <div class="main-article__inner cham-container">
    <nav class="main-article__breadcrumb" aria-label="Breadcrumb">
      <a href="{{ blog.url }}" class="main-article__back gold-link">{{ back_label }}</a>
    </nav>

    <header class="main-article__head" data-reveal>
      <span class="eyebrow">{{ date_str }} · {{ read_time }}</span>
      <h1 class="main-article__title font-display">{{ article.title }}</h1>
      {%- if article.author != blank -%}
        <p class="main-article__author">{{ 'sections.main_blog.by_author' | t: author: article.author }}</p>
      {%- endif -%}
      {%- if article.tags.size > 0 -%}
        <ul class="main-article__tags" aria-label="Tags">
          {%- for tag in article.tags -%}
            <li>
              <a href="{{ blog.url }}/tagged/{{ tag | handleize }}" class="main-article__tag">{{ tag }}</a>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </header>

    {%- if article.image -%}
      <figure class="main-article__hero" data-reveal data-reveal-delay="100">
        <img
          src="{{ article.image | image_url: width: 1600 }}"
          srcset="{{ article.image | image_url: width: 800 }} 800w, {{ article.image | image_url: width: 1600 }} 1600w, {{ article.image | image_url: width: 2400 }} 2400w"
          sizes="(min-width: 1024px) 90vw, 100vw"
          alt="{{ article.image.alt | default: article.title | escape }}"
          width="{{ article.image.width }}"
          height="{{ article.image.height }}"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="main-article__hero-img"
        >
      </figure>
    {%- endif -%}

    <div class="main-article__content rte" data-reveal data-reveal-delay="150">
      {{ article.content }}
    </div>
  </div>
</article>

{% stylesheet %}
  .main-article {
    width: 100%;
    padding-top: calc(var(--header-height) + 3rem);
    padding-bottom: 6rem;
  }

  @media (min-width: 1024px) {
    .main-article {
      padding-top: calc(var(--header-height) + 4rem);
      padding-bottom: 8rem;
    }
  }

  .main-article__breadcrumb {
    margin-bottom: 2.5rem;
  }

  .main-article__back {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: color-mix(in oklab, var(--foreground) 80%, transparent);
  }

  .main-article__back:hover,
  .main-article__back:focus-visible {
    color: var(--primary);
  }

  .main-article__head {
    max-width: 48rem;
    margin: 0 auto 3rem;
    text-align: center;
  }

  @media (min-width: 1024px) {
    .main-article__head {
      margin-bottom: 4rem;
    }
  }

  .main-article__head .eyebrow {
    justify-content: center;
  }

  .main-article__head .eyebrow::before {
    display: none;
  }

  .main-article__title {
    margin-top: 1.25rem;
    font-size: 2.5rem;
    line-height: 1.05;
  }

  @media (min-width: 1024px) {
    .main-article__title {
      font-size: 3.75rem;
    }
  }

  .main-article__author {
    margin-top: 1.25rem;
    font-style: italic;
    color: var(--muted-foreground);
    font-size: 0.9375rem;
  }

  .main-article__tags {
    margin: 1.5rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }

  .main-article__tag {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    border: 1px solid var(--border);
    color: color-mix(in oklab, var(--foreground) 75%, transparent);
    transition: border-color 0.3s ease, color 0.3s ease;
  }

  .main-article__tag:hover,
  .main-article__tag:focus-visible {
    border-color: var(--primary);
    color: var(--primary);
  }

  .main-article__hero {
    margin: 0 0 3rem;
    overflow: hidden;
    background-color: var(--surface);
  }

  @media (min-width: 1024px) {
    .main-article__hero {
      margin-bottom: 4.5rem;
    }
  }

  .main-article__hero-img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  /* === Article content (rich text from admin) === */
  .main-article__content {
    max-width: 44rem;
    margin: 0 auto;
    color: color-mix(in oklab, var(--foreground) 90%, transparent);
    font-size: 1.0625rem;
    line-height: 1.8;
  }

  .main-article__content > * + * {
    margin-top: 1.25rem;
  }

  .main-article__content h2 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    line-height: 1.15;
    margin-top: 3rem;
    color: var(--foreground);
  }

  .main-article__content h3 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.5rem;
    line-height: 1.2;
    margin-top: 2.25rem;
    color: var(--foreground);
  }

  .main-article__content h4 {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.0625rem;
    line-height: 1.3;
    margin-top: 2rem;
    color: var(--foreground);
  }

  .main-article__content a {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 0.2em;
    text-decoration-thickness: 1px;
    transition: color 0.3s ease;
  }

  .main-article__content a:hover,
  .main-article__content a:focus-visible {
    color: var(--primary-glow);
  }

  .main-article__content strong {
    color: var(--foreground);
    font-weight: 600;
  }

  .main-article__content em {
    font-style: italic;
  }

  .main-article__content ul,
  .main-article__content ol {
    margin-left: 1.5rem;
    padding-left: 0;
  }

  .main-article__content ul { list-style: disc; }
  .main-article__content ol { list-style: decimal; }

  .main-article__content li + li {
    margin-top: 0.375rem;
  }

  .main-article__content blockquote {
    border-left: 2px solid var(--primary);
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--foreground);
    font-size: 1.125rem;
  }

  .main-article__content img {
    display: block;
    width: 100%;
    height: auto;
    margin: 2rem 0;
  }

  .main-article__content hr {
    border: 0;
    border-top: 1px solid var(--border);
    margin: 3rem 0;
  }

  .main-article__content figure {
    margin: 2rem 0;
  }

  .main-article__content figcaption {
    margin-top: 0.75rem;
    font-size: 0.8125rem;
    color: var(--muted-foreground);
    text-align: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.main_article.name",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
