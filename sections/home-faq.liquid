<section class="home-faq full-width">
  <div class="home-faq__inner">
    <div class="home-faq__grid">
      <div class="home-faq__head" data-reveal>
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="home-faq__heading font-display">
          {{- section.settings.heading_lead -}}
          {%- if section.settings.heading_emphasis != blank %} <em>{{ section.settings.heading_emphasis }}</em>{%- endif -%}
        </h2>
        {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
          <a href="{{ section.settings.cta_url }}" class="home-faq__cta gold-link">
            {{ section.settings.cta_label }} →
          </a>
        {%- endif -%}
      </div>

      <div class="home-faq__list" data-reveal data-reveal-delay="100">
        {%- for block in section.blocks -%}
          <details class="home-faq__item" {{ block.shopify_attributes }}>
            <summary class="home-faq__question font-display">
              <span>{{ block.settings.question }}</span>
              <span class="home-faq__icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="5" x2="12" y2="19"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </summary>
            <div class="home-faq__answer">{{ block.settings.answer }}</div>
          </details>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .home-faq {
    padding-block: 8rem;
  }

  @media (min-width: 1024px) {
    .home-faq {
      padding-block: 11rem;
    }
  }

  .home-faq__inner {
    max-width: 1100px;
    margin-inline: auto;
    padding-inline: var(--page-padding-inline);
  }

  @media (min-width: 1024px) {
    .home-faq__inner {
      padding-inline: var(--page-padding-inline-lg);
    }
  }

  .home-faq__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .home-faq__grid {
      grid-template-columns: repeat(12, minmax(0, 1fr));
    }
    .home-faq__head { grid-column: span 4; }
    .home-faq__list { grid-column: span 8; }
  }

  .home-faq__heading {
    margin-top: 1rem;
    font-size: clamp(2.25rem, 5vw, 3rem);
    line-height: 1.05;
  }

  .home-faq__heading em {
    color: var(--primary);
    font-style: italic;
  }

  .home-faq__cta {
    display: inline-block;
    margin-top: 2rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.75rem;
    color: color-mix(in oklab, var(--foreground) 90%, transparent);
    transition: color 0.3s ease;
  }

  .home-faq__cta:hover {
    color: var(--primary);
  }

  .home-faq__item {
    border-bottom: 1px solid var(--border);
  }

  .home-faq__question {
    list-style: none;
    cursor: pointer;
    padding-block: 1.5rem;
    font-size: 1.25rem;
    line-height: 1.3;
    color: var(--foreground);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    transition: color 0.3s ease;
  }

  @media (min-width: 1024px) {
    .home-faq__question {
      font-size: 1.5rem;
    }
  }

  .home-faq__question::-webkit-details-marker {
    display: none;
  }

  .home-faq__question:hover {
    color: var(--primary);
  }

  .home-faq__icon {
    flex-shrink: 0;
    color: var(--primary);
    transition: transform 0.3s ease;
    display: inline-flex;
  }

  .home-faq__item[open] .home-faq__icon {
    transform: rotate(45deg);
  }

  .home-faq__answer {
    padding-bottom: 1.5rem;
    padding-right: 2rem;
    color: color-mix(in oklab, var(--foreground) 75%, transparent);
    line-height: 1.65;
    font-size: 1rem;
  }

  .home-faq__answer > p {
    margin: 0;
  }

  .home-faq__answer > p + p {
    margin-top: 1rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.home_faq.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Learn More"
    },
    {
      "type": "text",
      "id": "heading_lead",
      "label": "t:labels.heading_lead",
      "default": "Frequently"
    },
    {
      "type": "text",
      "id": "heading_emphasis",
      "label": "t:labels.heading_emphasis",
      "default": "asked."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "t:labels.cta_label",
      "default": "The Science"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "t:labels.cta_url"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "t:sections.home_faq.block_faq",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "t:labels.question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "t:labels.answer"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "t:sections.home_faq.presets_default",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "What is Cham about?",
            "answer": "<p>Cham is a skincare company developed with a research-backed approach grounded in skin biology and formulation science. We focus on formulation balance, skin comfort, and long-term radiance — not just surface shine.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How does science guide your formulation?",
            "answer": "<p>Skin is one of the body's most responsive organs, closely linked to the immune and sensory systems. Inflammation, hydration balance, barrier function and recovery are all influenced by cellular signaling within the skin. Decades of skin-biology research into how cells communicate and maintain balance inform how we approach modern formulation.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What is Cham's skincare philosophy?",
            "answer": "<p>We support skin balance rather than overpowering it with aggressive actives or heavy textures. Our focus is on how ingredients work together, how formulations feel, and how they align with natural skin processes over time.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How is Cham different from general skincare brands?",
            "answer": "<p>Many products create immediate brightness through oils, silicones or reflective films — effects that are often short-lived. Cham emphasises hydration balance, barrier support and calm skin conditions, alongside an instant feel of comfort.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Does Cham use single hero ingredients?",
            "answer": "<p>No. Skin response depends on how ingredients interact within a formulation, the quality of base materials and overall stability. We focus on synergy and integrity, not isolating one ingredient.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
