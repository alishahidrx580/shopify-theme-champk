{% doc %}
  Emits the global design tokens for the theme as CSS custom properties on :root.

  Two palettes ported verbatim from the React reference at src/styles.css:
  the default warm-ivory light palette on :root, and the "Noir & Gold" dark
  palette under :root[data-theme="dark"]. The active theme is applied by a
  small inline script in layout/theme.liquid before paint to avoid FOUC.

  Typography and layout tokens are theme-independent and live on :root only.

  @example
  {% render 'css-variables' %}
{% enddoc %}

{% style %}
  :root {
    --radius: 0.125rem;

    /* Surface */
    --background: oklch(0.975 0.012 80);
    --foreground: oklch(0.18 0.01 60);
    --surface: oklch(0.945 0.018 78);
    --card: oklch(0.97 0.014 80);
    --card-foreground: oklch(0.18 0.01 60);
    --popover: oklch(0.97 0.014 80);
    --popover-foreground: oklch(0.18 0.01 60);

    /* Accent — antique gold */
    --primary: oklch(0.58 0.13 70);
    --primary-foreground: oklch(0.985 0.008 80);
    --primary-glow: oklch(0.72 0.13 78);

    --secondary: oklch(0.91 0.015 78);
    --secondary-foreground: oklch(0.18 0.01 60);

    --muted: oklch(0.93 0.012 78);
    --muted-foreground: oklch(0.40 0.02 60);

    --accent: oklch(0.58 0.13 70);
    --accent-foreground: oklch(0.985 0.008 80);

    --destructive: oklch(0.55 0.20 27);
    --destructive-foreground: oklch(0.96 0.01 85);

    --border: oklch(0.30 0.04 70 / 0.18);
    --input: oklch(0.30 0.04 70 / 0.22);
    --ring: oklch(0.58 0.13 70 / 0.45);

    --gradient-gold: linear-gradient(135deg, var(--primary), var(--primary-glow));
    --shadow-gold: 0 24px 60px -28px color-mix(in oklab, var(--primary) 35%, transparent);

    /* Typography */
    --font-display: "Instrument Serif", ui-serif, Georgia, serif;
    --font-sans: "Karla", ui-sans-serif, system-ui, sans-serif;

    /* Layout */
    --page-max-width: 1400px;
    --page-padding-inline: 1.5rem;
    --page-padding-inline-lg: 2.5rem;
    --header-height: 4rem;

    /* Aliases used by the Skeleton baseline section grid utilities */
    --color-background: var(--background);
    --color-foreground: var(--foreground);
    --page-width: var(--page-max-width);
    --page-margin: var(--page-padding-inline);
    --style-border-radius-inputs: var(--radius);
  }

  :root[data-theme="dark"] {
    /* Surface — Noir */
    --background: oklch(0.16 0 0);
    --foreground: oklch(0.96 0.01 85);
    --surface: oklch(0.22 0 0);
    --card: oklch(0.22 0 0);
    --card-foreground: oklch(0.96 0.01 85);
    --popover: oklch(0.22 0 0);
    --popover-foreground: oklch(0.96 0.01 85);

    /* Accent — luminous gold */
    --primary: oklch(0.76 0.12 85);
    --primary-foreground: oklch(0.16 0 0);
    --primary-glow: oklch(0.88 0.10 88);

    --secondary: oklch(0.28 0 0);
    --secondary-foreground: oklch(0.96 0.01 85);

    --muted: oklch(0.24 0 0);
    --muted-foreground: oklch(0.70 0.01 85);

    --accent: oklch(0.76 0.12 85);
    --accent-foreground: oklch(0.16 0 0);

    --destructive: oklch(0.55 0.20 27);
    --destructive-foreground: oklch(0.96 0.01 85);

    --border: oklch(0.30 0.01 85 / 0.5);
    --input: oklch(0.30 0.01 85 / 0.5);
    --ring: oklch(0.76 0.12 85 / 0.5);

    --shadow-gold: 0 20px 60px -20px color-mix(in oklab, var(--primary) 35%, transparent);
  }

  @media (min-width: 1024px) {
    :root {
      --page-margin: var(--page-padding-inline-lg);
      --header-height: 5rem;
    }
  }

  body {
    transition: background-color 0.3s ease, color 0.3s ease;
  }
{% endstyle %}
