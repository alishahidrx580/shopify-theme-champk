<footer class="footer full-width" data-reveal>
  <div class="footer__inner">
    <div class="footer__grid">
      <div class="footer__brand">
        <a href="{{ routes.root_url }}" class="footer__logo" aria-label="{{ 'general.brand.name' | t }}">
          {{ 'logo.svg' | inline_asset_content }}
        </a>
        <p class="footer__tagline font-display">
          {{ section.settings.brand_tagline_lead }}
          {%- if section.settings.brand_tagline_emphasis != blank %}
            <br>
            <em>{{ section.settings.brand_tagline_emphasis }}</em>
          {%- endif -%}
        </p>
        <div class="footer__paragraph">
          {{ section.settings.brand_paragraph }}
        </div>

        {%- assign ig = section.settings.instagram_url -%}
        {%- assign fb = section.settings.facebook_url -%}
        {%- assign yt = section.settings.youtube_url -%}
        {%- if ig != blank or fb != blank or yt != blank -%}
          <ul class="footer__socials" aria-label="{{ 'sections.footer.socials_label' | t }}">
            {%- if ig != blank -%}
              <li>
                <a href="{{ ig }}" class="footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="{{ 'sections.footer.follow_instagram' | t }}">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                  </svg>
                </a>
              </li>
            {%- endif -%}
            {%- if fb != blank -%}
              <li>
                <a href="{{ fb }}" class="footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="{{ 'sections.footer.follow_facebook' | t }}">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                  </svg>
                </a>
              </li>
            {%- endif -%}
            {%- if yt != blank -%}
              <li>
                <a href="{{ yt }}" class="footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="{{ 'sections.footer.follow_youtube' | t }}">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/>
                    <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/>
                  </svg>
                </a>
              </li>
            {%- endif -%}
          </ul>
        {%- endif -%}
      </div>

      {%- assign columns = 'shop,brand,account' | split: ',' -%}
      {%- for key in columns -%}
        {%- assign menu_setting_id = key | prepend: 'menu_' -%}
        {%- assign title_key = key | prepend: 'sections.footer.group_' -%}
        {%- assign menu = section.settings[menu_setting_id] -%}

        {%- assign has_menu = false -%}
        {%- if menu != blank and menu.links.size > 0 -%}
          {%- assign has_menu = true -%}
        {%- endif -%}

        {%- assign auto_shop = false -%}
        {%- if key == 'shop' and has_menu == false and collections.all.products.size > 0 -%}
          {%- assign auto_shop = true -%}
        {%- endif -%}

        {%- if has_menu or auto_shop -%}
          <div class="footer__col {% if key == 'shop' %}footer__col--wide{% endif %}">
            <h4 class="eyebrow eyebrow--bare footer__col-title">{{ title_key | t }}</h4>
            <ul class="footer__links">
              {%- if has_menu -%}
                {%- for link in menu.links -%}
                  <li><a href="{{ link.url }}" class="footer__link">{{ link.title }}</a></li>
                {%- endfor -%}
              {%- else -%}
                <li>
                  <a href="{{ routes.all_products_collection_url }}" class="footer__link">
                    {{ 'sections.footer.shop_all_label' | t }}
                  </a>
                </li>
                {%- for product in collections.all.products -%}
                  <li><a href="{{ product.url }}" class="footer__link">{{ product.title }}</a></li>
                {%- endfor -%}
              {%- endif -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- assign current_year = 'now' | date: '%Y' -%}
    <div class="footer__bottom">
      <span>{{ 'sections.footer.copyright_html' | t: year: current_year }}</span>

      {%- if shop.policies.size > 0 -%}
        <nav class="footer__policies" aria-label="{{ 'sections.footer.policies_label' | t }}">
          {%- for policy in shop.policies -%}
            {%- if policy.body != blank -%}
              {%- unless forloop.first %}<span class="footer__policy-sep" aria-hidden="true">·</span>{%- endunless -%}
              <a href="{{ policy.url }}" class="footer__policy-link">{{ policy.title }}</a>
            {%- endif -%}
          {%- endfor -%}
        </nav>
      {%- endif -%}
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer {
    border-top: 1px solid var(--border);
    margin-top: 8rem;
    background-color: var(--background);
  }

  .footer__inner {
    max-width: var(--page-max-width);
    margin-inline: auto;
    padding: 5rem var(--page-padding-inline);
  }

  @media (min-width: 1024px) {
    .footer__inner {
      padding: 5rem var(--page-padding-inline-lg);
    }
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .footer__grid {
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 2rem;
    }
  }

  .footer__brand {
    grid-column: span 1;
  }

  @media (min-width: 1024px) {
    .footer__brand {
      grid-column: span 5;
    }
  }

  .footer__logo {
    display: inline-flex;
    color: var(--primary);
    margin-bottom: 1.5rem;
  }

  .footer__logo svg {
    height: 2rem;
    width: auto;
  }

  .footer__tagline {
    font-size: 1.5rem;
    line-height: 1.3;
    color: color-mix(in oklab, var(--foreground) 90%, transparent);
    max-width: 28rem;
  }

  .footer__tagline em {
    color: var(--primary);
    font-style: italic;
  }

  .footer__paragraph {
    margin-top: 1.5rem;
    font-size: 0.875rem;
    color: var(--muted-foreground);
    line-height: 1.65;
    max-width: 24rem;
  }

  .footer__socials {
    list-style: none;
    margin: 1.75rem 0 0;
    padding: 0;
    display: flex;
    gap: 0.75rem;
  }

  .footer__social-link {
    width: 2.75rem;
    height: 2.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    border-radius: 50%;
    color: var(--foreground);
    transition: color 0.3s ease, border-color 0.3s ease, background-color 0.3s ease;
  }

  .footer__social-link:hover,
  .footer__social-link:focus-visible {
    color: var(--primary-foreground);
    border-color: var(--primary);
    background-color: var(--primary);
  }

  .footer__col {
    grid-column: span 1;
  }

  @media (min-width: 1024px) {
    .footer__col {
      grid-column: span 2;
    }
    .footer__col--wide {
      grid-column: span 3;
    }
  }

  .footer__col-title {
    display: block;
    margin-bottom: 1.25rem;
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer__link {
    font-size: 0.875rem;
    color: color-mix(in oklab, var(--foreground) 80%, transparent);
    transition: color 0.3s ease;
  }

  .footer__link:hover,
  .footer__link:focus-visible {
    color: var(--primary);
  }

  .footer__bottom {
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--muted-foreground);
  }

  @media (min-width: 640px) {
    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      gap: 1rem;
    }
  }

  .footer__policies {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
  }

  .footer__policy-link {
    color: inherit;
    transition: color 0.3s ease;
  }

  .footer__policy-link:hover,
  .footer__policy-link:focus-visible {
    color: var(--primary);
  }

  .footer__policy-sep {
    color: inherit;
    opacity: 0.6;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.footer.name",
  "settings": [
    {
      "type": "header",
      "content": "t:general.content"
    },
    {
      "type": "text",
      "id": "brand_tagline_lead",
      "label": "t:labels.brand_tagline_lead",
      "default": "Skincare with intent."
    },
    {
      "type": "text",
      "id": "brand_tagline_emphasis",
      "label": "t:labels.brand_tagline_emphasis",
      "default": "Quiet radiance."
    },
    {
      "type": "richtext",
      "id": "brand_paragraph",
      "label": "t:labels.brand_paragraph",
      "default": "<p>Developed with French formulation standards. Precision-formulated to help skin look comfortable, even and naturally luminous.</p>"
    },
    {
      "type": "header",
      "content": "Social"
    },
    {
      "type": "text",
      "id": "instagram_url",
      "label": "t:labels.instagram_url",
      "default": "https://www.instagram.com/officialchambeauty/"
    },
    {
      "type": "text",
      "id": "facebook_url",
      "label": "t:labels.facebook_url",
      "default": "https://www.facebook.com/profile.php?id=61580977535370"
    },
    {
      "type": "text",
      "id": "youtube_url",
      "label": "t:labels.youtube_url",
      "default": "https://www.youtube.com/@Cham-skincare/shorts"
    },
    {
      "type": "paragraph",
      "content": "Policy links in the bottom row auto-render from Settings → Policies (Privacy, Refund, Terms, Shipping). Enable a policy there and it appears here automatically."
    },
    {
      "type": "header",
      "content": "t:general.layout"
    },
    {
      "type": "link_list",
      "id": "menu_shop",
      "label": "t:labels.linklist_shop"
    },
    {
      "type": "link_list",
      "id": "menu_brand",
      "label": "t:labels.linklist_brand"
    },
    {
      "type": "link_list",
      "id": "menu_account",
      "label": "t:labels.linklist_account"
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  }
}
{% endschema %}
