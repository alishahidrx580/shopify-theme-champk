<section class="home-pillars full-width">
  <div class="home-pillars__inner cham-container">
    <div class="home-pillars__head" data-reveal>
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="home-pillars__heading font-display">
        {{- section.settings.heading_lead -}}
        {%- if section.settings.heading_emphasis != blank %} <em>{{ section.settings.heading_emphasis }}</em>{%- endif -%}
      </h2>
    </div>

    <div class="home-pillars__grid">
      {%- for block in section.blocks -%}
        <div class="home-pillars__item" data-reveal data-reveal-delay="{{ forloop.index0 | times: 100 }}" {{ block.shopify_attributes }}>
          {%- if block.settings.number != blank -%}
            <span class="home-pillars__number font-display">{{ block.settings.number }}</span>
          {%- endif -%}
          <h3 class="home-pillars__title font-display">{{ block.settings.title }}</h3>
          <div class="home-pillars__body">{{ block.settings.body }}</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .home-pillars {
    padding-block: 8rem;
  }

  .home-pillars__head {
    max-width: 42rem;
  }

  .home-pillars__heading {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    line-height: 1.05;
    margin-top: 1rem;
  }

  .home-pillars__heading em {
    color: var(--primary);
    font-style: italic;
  }

  .home-pillars__grid {
    display: grid;
    grid-template-columns: 1fr;
    column-gap: 2rem;
    row-gap: 3rem;
    margin-top: 5rem;
  }

  @media (min-width: 768px) {
    .home-pillars__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .home-pillars__item {
    border-top: 1px solid var(--border);
    padding-top: 2rem;
  }

  .home-pillars__number {
    color: var(--primary);
    font-size: 1.25rem;
  }

  .home-pillars__title {
    font-size: 1.875rem;
    line-height: 1.1;
    margin-top: 0.75rem;
  }

  @media (min-width: 1024px) {
    .home-pillars__title {
      font-size: 2.25rem;
    }
  }

  .home-pillars__body {
    margin-top: 1rem;
    color: color-mix(in oklab, var(--foreground) 75%, transparent);
    line-height: 1.65;
  }

  .home-pillars__body > p {
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.home_pillars.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Composition Principles"
    },
    {
      "type": "text",
      "id": "heading_lead",
      "label": "t:labels.heading_lead",
      "default": "Balanced for"
    },
    {
      "type": "text",
      "id": "heading_emphasis",
      "label": "t:labels.heading_emphasis",
      "default": "Optimum Glow"
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "t:sections.home_pillars.block_pillar",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "t:labels.pillar_number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.pillar_title",
          "default": "Title"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "t:labels.pillar_body",
          "default": "<p>Pillar body copy.</p>"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "t:sections.home_pillars.presets_default",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "number": "01",
            "title": "Comfort",
            "body": "<p>Textures designed to feel weightless and kind on every skin type. No heaviness, no residue.</p>"
          }
        },
        {
          "type": "pillar",
          "settings": {
            "number": "02",
            "title": "Balance",
            "body": "<p>Hydration, barrier and pH supported in equilibrium — never stripped or overstimulated.</p>"
          }
        },
        {
          "type": "pillar",
          "settings": {
            "number": "03",
            "title": "Finish",
            "body": "<p>A soft, even, naturally luminous look that comes from skin that simply feels good.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
