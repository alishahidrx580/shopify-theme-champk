{%- liquid
  assign current_variant = product.selected_or_first_available_variant

  assign short_name       = product.metafields.custom.short_name | default: product.title
  assign subtitle         = product.metafields.custom.subtitle
  assign hero_statement   = product.metafields.custom.hero_statement
  assign science_note     = product.metafields.custom.science_note
  assign how_to_use       = product.metafields.custom.how_to_use
  assign full_ingredients = product.metafields.custom.full_ingredients
  assign category_label   = product.metafields.custom.category | default: product.type
  assign claims_list      = product.metafields.custom.claims.value
  assign volume           = product.metafields.custom.volume

  # Ingredients meta — sourced from custom.key_ingredients (list of single-line text).
  # Works whether the value returns as a list OR a single "/", "·" or "," string.
  assign ingredient_raw = product.metafields.custom.key_ingredients.value
  assign ingredient_items = ''
  if ingredient_raw != blank
    assign ing_joined = ingredient_raw | join: '|'
    assign ing_norm = ing_joined | replace: ' / ', '|' | replace: '/', '|' | replace: ' · ', '|' | replace: '·', '|' | replace: ', ', '|' | replace: ',', '|'
    assign ingredient_items = ing_norm | split: '|'
  endif

  assign price_formatted  = current_variant.price | money
  assign atc_label        = 'Add to bag'
  assign sold_out_label   = 'products.sold_out' | t

  if product.has_only_default_variant
    assign variant_label = price_formatted
  else
    assign variant_label = current_variant.title | append: ' / ' | append: price_formatted
  endif

  assign gallery_fit = section.settings.gallery_fit | default: 'cover'
  assign gallery_ratio = section.settings.gallery_ratio | default: '3 / 4'
  assign focal_x     = section.settings.gallery_focal_x | default: 50
  assign focal_y     = section.settings.gallery_focal_y | default: 50

  if category_label != blank
    assign breadcrumb_label = category_label
  else
    assign breadcrumb_label = 'sections.main_product.breadcrumb_root' | t
  endif
-%}

<section class="main-product full-width" data-product-section data-product-handle="{{ product.handle }}" style="--gallery-ratio: {{ gallery_ratio }};">
  <div class="main-product__inner cham-container">
    <div class="main-product__grid">

      <div class="main-product__gallery" data-gallery>
        <div class="main-product__gallery-track" data-gallery-track>
          {%- if product.images.size > 0 -%}
            {%- for image in product.images -%}
              {%- liquid
                assign mf_x = 'img' | append: forloop.index | append: '_x'
                assign mf_y = 'img' | append: forloop.index | append: '_y'
                assign sx = product.metafields.custom[mf_x].value
                assign sy = product.metafields.custom[mf_y].value
                if sx == blank
                  assign slider_x = 'image_' | append: forloop.index | append: '_x'
                  assign sx = section.settings[slider_x] | default: focal_x
                endif
                if sy == blank
                  assign slider_y = 'image_' | append: forloop.index | append: '_y'
                  assign sy = section.settings[slider_y] | default: focal_y
                endif
                assign img_focal = sx | append: '% ' | append: sy | append: '%'
              -%}
              <figure class="main-product__tile" data-gallery-tile>
                <img
                  src="{{ image | image_url: width: 1200 }}"
                  srcset="{{ image | image_url: width: 600 }} 600w, {{ image | image_url: width: 1200 }} 1200w, {{ image | image_url: width: 1800 }} 1800w"
                  sizes="(min-width: 1024px) 30vw, 100vw"
                  alt="{{ product.title | escape }}"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                  class="main-product__tile-img"
                  style="object-fit: {{ gallery_fit }}; object-position: {{ img_focal }};"
                  {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
                  decoding="async"
                >
              </figure>
            {%- endfor -%}
          {%- else -%}
            <figure class="main-product__tile">
              {{ 'product-1' | placeholder_svg_tag: 'main-product__tile-img' }}
            </figure>
          {%- endif -%}
        </div>

        {%- if product.images.size > 1 -%}
          <div class="main-product__gallery-progress" aria-hidden="true">
            <span class="main-product__gallery-progress-fill" data-gallery-progress></span>
          </div>
        {%- endif -%}
      </div>

      <div class="main-product__info">

        <div class="main-product__header">
          <nav class="main-product__breadcrumb" aria-label="Breadcrumb">
            <a href="{{ routes.all_products_collection_url }}" class="main-product__breadcrumb-link eyebrow eyebrow--bare">
              {{ breadcrumb_label }}
            </a>
            <span class="main-product__breadcrumb-sep" aria-hidden="true">&gt;</span>
            <span class="main-product__breadcrumb-current">{{ short_name }}</span>
          </nav>

          <h1 class="main-product__title font-display">{{ product.title }}</h1>

          {%- if subtitle != blank -%}
            <p class="main-product__subtitle">{{ subtitle }}</p>
          {%- endif -%}

          {%- if ingredient_items != blank and ingredient_items.size > 0 -%}
            <p class="main-product__ingredients-meta">
              {%- for ing in ingredient_items -%}
                {%- assign ing_clean = ing | strip -%}
                {%- if ing_clean != blank -%}
                  {{- ing_clean -}}
                  {%- unless forloop.last %} &middot; {% endunless -%}
                {%- endif -%}
              {%- endfor -%}
            </p>
          {%- endif -%}

          {%- if product.metafields.judgeme.badge != blank -%}
            <a href="#reviews" class="main-product__rating">{{ product.metafields.judgeme.badge }}</a>
          {%- endif -%}
        </div>

        {%- if hero_statement != blank -%}
          <p class="main-product__hero-statement font-display">{{ hero_statement }}</p>
        {%- endif -%}

        {%- if product.description != blank -%}
          <div class="main-product__description rte" data-description>{{ product.description }}</div>
          <button type="button" class="main-product__see-more" data-see-more aria-expanded="false" data-more="See more" data-less="See less">
            See more
          </button>
        {%- endif -%}

        <form
          method="post"
          action="{{ routes.cart_add_url }}"
          accept-charset="UTF-8"
          enctype="multipart/form-data"
          class="main-product__form"
          data-product-form
          data-unit-price="{{ current_variant.price }}"
          novalidate
        >
          <input type="hidden" name="form_type" value="product">
          <input type="hidden" name="utf8" value="&#x2713;">
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>
          <input type="hidden" name="quantity" value="1">

          <div class="main-product__size-line">
            <span data-variant-label>{{ variant_label }}</span>
            {%- if volume != blank -%}
              <span class="main-product__volume">{{ volume }}</span>
            {%- endif -%}
          </div>

          <button
            type="submit"
            class="main-product__atc"
            data-atc
            data-atc-label="{{ atc_label | escape }}"
            data-sold-out-label="{{ sold_out_label | escape }}"
            {% if current_variant.available == false %}disabled{% endif %}
          >
            <span data-atc-label>{% if current_variant.available %}{{ atc_label }}{% else %}{{ sold_out_label }}{% endif %}</span>
            <span class="main-product__atc-price" data-atc-price>{{ variant_label }}</span>
          </button>
        </form>

        {%- if claims_list != blank and claims_list.size > 0 -%}
          <ul class="main-product__claims" role="list">
            {%- for claim in claims_list -%}
              <li class="main-product__claim">
                <svg class="main-product__claim-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                <span>{{ claim }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        <div class="main-product__accordion">
          <details class="main-product__accordion-item">
            <summary class="main-product__accordion-summary">
              <span>Benefits</span>
              <span class="main-product__accordion-icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </summary>
            <div class="main-product__accordion-body">
              {%- if science_note != blank -%}
                <div class="rte">{{ science_note }}</div>
              {%- endif -%}
            </div>
          </details>

          <details class="main-product__accordion-item">
            <summary class="main-product__accordion-summary">
              <span>Ingredients</span>
              <span class="main-product__accordion-icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </summary>
            <div class="main-product__accordion-body main-product__accordion-body--ingredients">{{ full_ingredients }}</div>
          </details>

          <details class="main-product__accordion-item">
            <summary class="main-product__accordion-summary">
              <span>How to use</span>
              <span class="main-product__accordion-icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </span>
            </summary>
            <div class="main-product__accordion-body">{{ how_to_use }}</div>
          </details>
        </div>
      </div>
    </div>
  </div>

  <div class="main-product__sticky-bar" data-sticky-bar hidden>
    <div class="main-product__sticky-inner cham-container">
      <span class="main-product__sticky-title font-display">{{ short_name }}</span>
      <div class="main-product__sticky-actions">
        <button type="button" class="main-product__atc main-product__atc--sticky" data-atc-sticky {% if current_variant.available == false %}disabled{% endif %}>
          <span data-atc-label>{% if current_variant.available %}{{ atc_label }}{% else %}{{ sold_out_label }}{% endif %}</span>
          <span class="main-product__atc-price" data-atc-price>{{ variant_label }}</span>
        </button>
      </div>
    </div>
  </div>

  <script type="application/json" data-product-variants-json>
    {{ product.variants | json }}
  </script>
</section>

{% stylesheet %}
  .main-product {
    width: 100%;
    padding-top: calc(var(--header-height) + 1.5rem);
    padding-bottom: 2.5rem;
  }

  @media (min-width: 1024px) {
    .main-product {
      padding-top: calc(var(--header-height) + 2.5rem);
      padding-bottom: 4rem;
    }
  }

  .main-product__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    grid-template-areas:
      "gallery"
      "info";
    gap: 1.5rem;
  }

  @media (min-width: 1024px) {
    .main-product__grid {
      grid-template-columns: minmax(0, 1.45fr) minmax(0, 1fr);
      grid-template-areas: "gallery info";
      column-gap: 4rem;
      align-items: start;
    }
  }

  .main-product__gallery { grid-area: gallery; align-self: start; }
  .main-product__info    { grid-area: info; }

  /* Header now lives inside the info column; small gap before the hero statement */
  .main-product__header { margin-bottom: 1.5rem; }

  .main-product__breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--foreground) 60%, transparent);
  }

  .main-product__breadcrumb-link { color: inherit; transition: color 0.3s ease; }
  .main-product__breadcrumb-link:hover { color: var(--primary); }
  .main-product__breadcrumb-sep { color: color-mix(in oklab, var(--foreground) 35%, transparent); }
  .main-product__breadcrumb-current { color: color-mix(in oklab, var(--foreground) 85%, transparent); }

  .main-product__title {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 300;
    line-height: 1.02;
    letter-spacing: -0.015em;
    margin: 0;
  }

  @media (min-width: 1024px) {
    .main-product__title { font-size: clamp(2.75rem, 3.6vw, 4rem); }
  }

  .main-product__subtitle {
    margin: 0.75rem 0 0;
    font-size: 1rem;
    font-style: italic;
    color: color-mix(in oklab, var(--foreground) 70%, transparent);
  }

  .main-product__ingredients-meta {
    margin: 0.85rem 0 0;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--muted-foreground);
  }

  .main-product__rating { display: inline-block; margin-top: 1rem; color: inherit; }
  .main-product__rating:empty { display: none; margin: 0; }
  .main-product__rating .jdgm-star.jdgm--on,
  .main-product__rating .jdgm-star.jdgm--half { color: var(--primary); }
  .main-product__rating .jdgm-star.jdgm--off  { color: color-mix(in oklab, var(--foreground) 25%, transparent); }
  .main-product__rating .jdgm-prev-badge__text {
    color: var(--muted-foreground);
    font-size: 0.75rem;
    letter-spacing: 0.02em;
  }

  .main-product__gallery-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 0;
    margin: 0;
    padding: 0;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .main-product__gallery-track::-webkit-scrollbar { display: none; }

  .main-product__tile {
    flex: 0 0 100%;
    scroll-snap-align: start;
    margin: 0;
    aspect-ratio: var(--gallery-ratio, 3 / 4);
    overflow: hidden;
    background-color: var(--surface);
  }

  .main-product__tile-img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .main-product__gallery-progress {
    margin-top: 0.75rem;
    height: 2px;
    background-color: var(--border);
    overflow: hidden;
  }
  .main-product__gallery-progress-fill {
    display: block;
    height: 100%;
    width: 30%;
    background-color: var(--primary);
    transition: transform 0.2s ease, width 0.2s ease;
    transform-origin: left;
  }

  @media (min-width: 1024px) {
    .main-product__gallery-track {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.5rem;
      overflow: visible;
    }
    .main-product__tile { flex: none; aspect-ratio: var(--gallery-ratio, 3 / 4); }
    .main-product__gallery-progress { display: none; }
  }

  @media (min-width: 1024px) {
    .main-product__info {
      position: sticky;
      top: calc(var(--header-height) + 1.5rem);
      align-self: start;
    }
  }

  .main-product__hero-statement {
    margin: 0 0 1.5rem;
    font-size: 1.25rem;
    line-height: 1.3;
    font-style: italic;
    color: color-mix(in oklab, var(--foreground) 85%, transparent);
  }

  .main-product__description {
    color: color-mix(in oklab, var(--foreground) 80%, transparent);
    line-height: 1.65;
  }
  .main-product__description > p { margin: 0; }
  .main-product__description > p + p { margin-top: 1rem; }

  .main-product__see-more {
    margin-top: 0.5rem;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 3px;
    background: none;
    border: 0;
    cursor: pointer;
  }

  @media (max-width: 1023px) {
    .main-product__description.is-clamped {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  }

  @media (min-width: 1024px) {
    .main-product__see-more { display: none; }
  }

  .main-product__size-line {
    margin-top: 1.75rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.95rem;
    color: var(--foreground);
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .main-product__volume {
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted-foreground);
    flex-shrink: 0;
  }

  .main-product__replenishment {
    margin-top: 0.25rem;
    border-bottom: 1px solid var(--border);
  }
  .main-product__replenishment-summary {
    list-style: none;
    cursor: pointer;
    padding: 1rem 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.95rem;
    color: var(--foreground);
  }
  .main-product__replenishment-summary::-webkit-details-marker { display: none; }
  .main-product__replenishment-icon { color: var(--primary); display: inline-flex; transition: transform 0.3s ease; }
  .main-product__replenishment[open] .main-product__replenishment-icon { transform: rotate(45deg); }
  .main-product__replenishment-body { padding-bottom: 1.25rem; }
  .main-product__plan {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.4rem 0;
    font-size: 0.875rem;
    color: color-mix(in oklab, var(--foreground) 80%, transparent);
    cursor: pointer;
  }
  .main-product__plan input { accent-color: var(--primary); }
  .main-product__replenishment-note {
    margin: 0;
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--muted-foreground);
  }

  .main-product__atc {
    width: 100%;
    min-height: 3.75rem;
    margin-top: 1.5rem;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background-color: var(--primary);
    color: var(--primary-foreground);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.8125rem;
    font-weight: 500;
    border: 0;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }
  .main-product__atc:hover:not([disabled]) { background-color: var(--primary-glow); }
  .main-product__atc:focus-visible { outline: 2px solid var(--ring); outline-offset: 2px; }
  .main-product__atc[disabled] { opacity: 0.5; cursor: not-allowed; }
  .main-product__atc[data-loading="true"] { opacity: 0.7; cursor: progress; }
  .main-product__atc-price { letter-spacing: 0.08em; }

  /* === Claims (checkmark row, below Add to bag) === */
  .main-product__claims {
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.5rem;
  }
  .main-product__claim {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--foreground) 75%, transparent);
  }
  .main-product__claim-icon { color: var(--primary); flex: none; }

  .main-product__installments {
    margin-top: 1rem;
    font-size: 0.8125rem;
    color: color-mix(in oklab, var(--foreground) 70%, transparent);
  }

  .main-product__shipping-note {
    margin-top: 1.25rem;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--muted-foreground);
  }

  .main-product__accordion {
    margin-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .main-product__accordion-item { border-bottom: 1px solid var(--border); }
  .main-product__accordion-summary {
    list-style: none;
    cursor: pointer;
    padding-block: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.95rem;
    color: var(--foreground);
    transition: color 0.3s ease;
  }
  .main-product__accordion-summary::-webkit-details-marker { display: none; }
  .main-product__accordion-summary:hover { color: var(--primary); }
  .main-product__accordion-icon { color: var(--primary); transition: transform 0.3s ease; display: inline-flex; }
  .main-product__accordion-item[open] .main-product__accordion-icon { transform: rotate(45deg); }
  .main-product__accordion-body {
    padding-bottom: 1.5rem;
    color: color-mix(in oklab, var(--foreground) 80%, transparent);
    line-height: 1.65;
    font-size: 0.875rem;
  }
  .main-product__accordion-body > p  { margin: 0; }
  .main-product__accordion-body > p + p { margin-top: 1rem; }
  .main-product__accordion-body--ingredients {
    font-size: 0.75rem;
    letter-spacing: 0.02em;
    color: color-mix(in oklab, var(--foreground) 70%, transparent);
  }
  .main-product__benefit-list { margin: 0 0 0.75rem; padding-left: 1.1rem; }
  .main-product__benefit-list li { margin-bottom: 0.4rem; }

  .main-product__sticky-bar {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 50;
    background-color: var(--background);
    border-top: 1px solid var(--border);
    transform: translateY(100%);
    transition: transform 0.35s ease;
  }
  .main-product__sticky-bar.is-visible { transform: translateY(0); }
  .main-product__sticky-bar[hidden] { display: block; }

  @media (min-width: 1024px) {
    .main-product__sticky-bar {
      bottom: auto;
      top: 0;
      border-top: 0;
      border-bottom: 1px solid var(--border);
      transform: translateY(-100%);
    }
    .main-product__sticky-bar.is-visible { transform: translateY(0); }
  }

  .main-product__sticky-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
  }
  .main-product__sticky-title {
    font-size: 1.25rem;
    font-weight: 300;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  @media (max-width: 1023px) {
    .main-product__sticky-title { display: none; }
  }
  .main-product__sticky-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex: 1 1 auto;
    justify-content: flex-end;
  }
  .main-product__atc--sticky {
    margin-top: 0;
    min-height: 3rem;
    flex: 1 1 auto;
    max-width: 22rem;
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var section = document.currentScript.closest('[data-product-section]');
    if (!section) {
      var all = document.querySelectorAll('[data-product-section]');
      section = all[all.length - 1];
    }
    if (!section) return;

    var form        = section.querySelector('[data-product-form]');
    var stickyBar   = section.querySelector('[data-sticky-bar]');
    var header      = section.querySelector('.main-product__header');
    var description = section.querySelector('[data-description]');
    var seeMore     = section.querySelector('[data-see-more]');
    var track       = section.querySelector('[data-gallery-track]');
    var progress    = section.querySelector('[data-gallery-progress]');

    function addToCart(btn) {
      if (!form || btn.disabled) return;
      var fd = new FormData(form);
      btn.setAttribute('data-loading', 'true');
      fetch('/cart/add.js', { method: 'POST', body: fd, headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function (r) { return r.json(); })
        .then(function () {
          btn.removeAttribute('data-loading');
          document.dispatchEvent(new CustomEvent('cart:refresh'));
          document.dispatchEvent(new CustomEvent('cart:open'));
        })
        .catch(function () {
          btn.removeAttribute('data-loading');
          form.submit();
        });
    }

    if (form) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        addToCart(section.querySelector('[data-atc]'));
      });
    }
    var stickyAtc = section.querySelector('[data-atc-sticky]');
    if (stickyAtc) stickyAtc.addEventListener('click', function () { addToCart(stickyAtc); });

    if (description && seeMore) {
      if (window.matchMedia('(max-width: 1023px)').matches) description.classList.add('is-clamped');
      seeMore.addEventListener('click', function () {
        var clamped = description.classList.toggle('is-clamped');
        seeMore.setAttribute('aria-expanded', String(!clamped));
        seeMore.textContent = clamped ? (seeMore.dataset.more || 'See more') : (seeMore.dataset.less || 'See less');
      });
    }

    if (track && progress) {
      var updateProgress = function () {
        var max   = track.scrollWidth - track.clientWidth;
        var ratio = max > 0 ? track.scrollLeft / max : 0;
        var slides = track.children.length || 1;
        progress.style.width     = (100 / slides) + '%';
        progress.style.transform = 'translateX(' + (ratio * (slides - 1) * 100) + '%)';
      };
      track.addEventListener('scroll', updateProgress, { passive: true });
      window.addEventListener('resize', updateProgress);
      updateProgress();
    }

    if (stickyBar && header && 'IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) {
          stickyBar.classList.toggle('is-visible', !en.isIntersecting);
        });
      }, { rootMargin: '-80px 0px 0px 0px', threshold: 0 });
      io.observe(header);
    }
  })();
{% endjavascript %}

