{%- liquid
  assign align = section.settings.alignment | default: 'left'
  assign width = section.settings.width | default: 'medium'
  assign bg = section.settings.background | default: 'none'
  assign heading_lead = section.settings.heading_lead
  assign heading_emphasis = section.settings.heading_emphasis
  assign body = section.settings.body
-%}

<section class="product-body-text full-width product-body-text--align-{{ align }} product-body-text--w-{{ width }} product-body-text--bg-{{ bg }}">
  <div class="product-body-text__inner cham-container">
    <div class="product-body-text__block" data-reveal>
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      {%- if heading_lead != blank or heading_emphasis != blank -%}
        <h2 class="product-body-text__heading font-display">
          {{- heading_lead -}}
          {%- if heading_emphasis != blank %} <em>{{ heading_emphasis }}</em>{%- endif -%}
        </h2>
      {%- endif -%}

      {%- if body != blank -%}
        <div class="product-body-text__body rte">{{ body }}</div>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .product-body-text {
    width: 100%;
    padding-block: 4.5rem;
  }

  @media (min-width: 1024px) {
    .product-body-text {
      padding-block: 7rem;
    }
  }

  .product-body-text--bg-surface {
    background-color: var(--surface);
  }

  /* === Block width === */
  .product-body-text__block {
    max-width: 52rem;
  }

  .product-body-text--w-narrow .product-body-text__block { max-width: 38rem; }
  .product-body-text--w-medium .product-body-text__block { max-width: 52rem; }
  .product-body-text--w-wide .product-body-text__block { max-width: 64rem; }

  /* === Alignment === */
  .product-body-text--align-center .product-body-text__block {
    margin-inline: auto;
    text-align: center;
  }

  .product-body-text--align-center .product-body-text__body {
    margin-inline: auto;
  }

  /* === Heading === */
  .product-body-text__heading {
    margin-top: 1.25rem;
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.015em;
  }

  .product-body-text__heading em {
    color: var(--primary);
    font-style: italic;
  }

  /* === Body === */
  .product-body-text__body {
    margin-top: 1.75rem;
    color: color-mix(in oklab, var(--foreground) 85%, transparent);
    line-height: 1.75;
    font-size: 1.0625rem;
  }

  .product-body-text__body > :first-child { margin-top: 0; }
  .product-body-text__body > p { margin: 0; }
  .product-body-text__body > p + p { margin-top: 1.25rem; }

  .product-body-text__body a {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .product-body-text__body h3,
  .product-body-text__body h4 {
    font-weight: 400;
    margin-top: 2rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Body text",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow"
    },
    {
      "type": "text",
      "id": "heading_lead",
      "label": "t:labels.heading_lead"
    },
    {
      "type": "text",
      "id": "heading_emphasis",
      "label": "t:labels.heading_emphasis"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Share the story behind the formula, the ritual, or the philosophy. Keep it considered and unhurried — a few short paragraphs read as more luxurious than one long block.</p>"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Content width",
      "options": [
        { "value": "narrow", "label": "Narrow" },
        { "value": "medium", "label": "Medium" },
        { "value": "wide", "label": "Wide" }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "background",
      "label": "Background",
      "options": [
        { "value": "none", "label": "Default" },
        { "value": "surface", "label": "Surface" }
      ],
      "default": "none"
    }
  ],
  "presets": [
    {
      "name": "Body text"
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
