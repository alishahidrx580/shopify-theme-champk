{% doc %}
  Renders the global side-drawer cart. Hydrates server-side from the `cart`
  object; client-side mutations (qty change, remove) go through Shopify's
  Ajax Cart API in assets/cart-drawer.js.

  Triggered by any element with `data-cart-trigger` (typically the header
  cart icon button). Closed by `data-cart-close`, the Esc key, or clicking
  the overlay.

  @example
  {% render 'cart-drawer' %}
{% enddoc %}

<div class="cart-drawer" data-cart-drawer aria-hidden="true">
  <div class="cart-drawer__overlay" data-cart-close></div>

  <aside class="cart-drawer__panel" role="dialog" aria-modal="true" aria-labelledby="cart-drawer-title">
    <header class="cart-drawer__header">
      <h3 class="eyebrow" id="cart-drawer-title">
        {{ 'sections.cart_drawer.title' | t }}
        <span class="cart-drawer__count" data-cart-count-text>
          {%- if cart.item_count > 0 -%}({{ cart.item_count }}){%- endif -%}
        </span>
      </h3>
      <button type="button" class="cart-drawer__close" data-cart-close aria-label="{{ 'general.accessibility.close_cart' | t }}">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </header>

    {%- if cart.item_count == 0 -%}
      <div class="cart-drawer__empty">
        <p class="cart-drawer__empty-heading font-display">
          {{ 'sections.cart_drawer.empty_heading_lead' | t }}
          <em>{{ 'sections.cart_drawer.empty_heading_emphasis' | t }}</em>
        </p>
        <p class="cart-drawer__empty-body">
          {{ 'sections.cart_drawer.empty_paragraph' | t }}
        </p>
        <a href="{{ routes.all_products_collection_url }}" class="cart-drawer__empty-cta" data-cart-close>
          {{ 'sections.cart_drawer.empty_cta' | t }}
        </a>
      </div>
    {%- else -%}
      <ul class="cart-drawer__items">
        {%- for item in cart.items -%}
          {%- assign volume = item.product.metafields.custom.volume -%}
          {%- unless item.product.has_only_default_variant -%}
            {%- assign volume = item.variant.title -%}
          {%- endunless -%}
          {%- assign has_compare = false -%}
          {%- if item.variant.compare_at_price > item.final_price -%}
            {%- assign has_compare = true -%}
          {%- endif -%}
          <li class="cart-drawer__item" data-line-key="{{ item.key }}">
            <a href="{{ item.url }}" class="cart-drawer__item-image" data-cart-close>
              {%- if item.image -%}
                <img
                  src="{{ item.image | image_url: width: 160 }}"
                  alt="{{ item.product.title | escape }}"
                  loading="lazy"
                  width="80"
                  height="96"
                >
              {%- endif -%}
            </a>
            <div class="cart-drawer__item-body">
              <div class="cart-drawer__item-header">
                <a href="{{ item.url }}" class="cart-drawer__item-title font-display" data-cart-close>
                  {{ item.product.title }}
                </a>
                <span class="cart-drawer__item-line-price">{{ item.final_line_price | money }}</span>
              </div>
              {%- if volume != blank -%}
                <p class="cart-drawer__item-volume">{{ volume }}</p>
              {%- endif -%}
              <p class="cart-drawer__item-unit-pricing">
                <span class="cart-drawer__item-unit-price">{{ item.final_price | money }}</span>
                {%- if has_compare -%}
                  <span class="cart-drawer__item-compare">{{ item.variant.compare_at_price | money }}</span>
                {%- endif -%}
              </p>
              <div class="cart-drawer__item-controls">
                <div class="cart-drawer__qty">
                  <button
                    type="button"
                    class="cart-drawer__qty-btn"
                    data-cart-qty
                    data-line="{{ forloop.index }}"
                    data-delta="-1"
                    aria-label="{{ 'general.accessibility.decrease_quantity' | t }}"
                  >
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
                      <line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                  </button>
                  <span class="cart-drawer__qty-value">{{ item.quantity }}</span>
                  <button
                    type="button"
                    class="cart-drawer__qty-btn"
                    data-cart-qty
                    data-line="{{ forloop.index }}"
                    data-delta="1"
                    aria-label="{{ 'general.accessibility.increase_quantity' | t }}"
                  >
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
                      <line x1="12" y1="5" x2="12" y2="19"/>
                      <line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                  </button>
                </div>
                <button
                  type="button"
                  class="cart-drawer__item-remove"
                  data-cart-remove
                  data-line="{{ forloop.index }}"
                  aria-label="{{ 'general.accessibility.remove_item' | t }}"
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="3 6 5 6 21 6"/>
                    <path d="M19 6l-2 14a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2L5 6"/>
                    <path d="M10 11v6M14 11v6"/>
                    <path d="M9 6V4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2"/>
                  </svg>
                </button>
              </div>
            </div>
          </li>
        {%- endfor -%}
      </ul>

      <footer class="cart-drawer__footer">
        {%- assign gift_message = cart.attributes['Gift Message'] -%}
        {%- assign gift_message_max = settings.gift_message_max | default: 240 -%}

        {%- if gift_message != blank -%}
          <details class="cart-drawer__gift-options" data-cart-gift-options open>
            <summary class="cart-drawer__gift-summary">
              <span class="cart-drawer__gift-summary-label">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 12 20 22 4 22 4 12"/>
                  <rect x="2" y="7" width="20" height="5"/>
                  <line x1="12" y1="22" x2="12" y2="7"/>
                  <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/>
                  <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
                </svg>
                <span>{{ 'sections.cart_drawer.gift_message_label' | t }}</span>
              </span>
              <span class="cart-drawer__gift-toggle" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <line class="cart-drawer__gift-toggle-vertical" x1="12" y1="5" x2="12" y2="19"/>
                </svg>
              </span>
            </summary>

            <div class="cart-drawer__gift-message-field">
              <textarea
                id="CartDrawerGiftMessage"
                data-cart-gift-message
                maxlength="{{ gift_message_max }}"
                placeholder="{{ 'sections.cart_drawer.gift_message_placeholder' | t }}"
                rows="2"
              >{{ gift_message }}</textarea>
              <p class="cart-drawer__gift-message-meta">
                <span class="cart-drawer__gift-message-status" data-cart-gift-message-status hidden>
                  {{ 'sections.cart_drawer.gift_message_saved' | t }}
                </span>
                <span class="cart-drawer__gift-message-count">
                  <span data-cart-gift-message-count>{{ gift_message.size }}</span>/{{ gift_message_max }}
                </span>
              </p>
            </div>
          </details>
        {%- endif -%}

        <details class="cart-drawer__discount"{% if cart.cart_level_discount_applications.size > 0 %} open{% endif %}>
          <summary class="cart-drawer__discount-summary">
            <span class="cart-drawer__discount-label">{{ 'sections.cart_drawer.discount_label' | t }}</span>
            <span class="cart-drawer__discount-toggle" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <line class="cart-drawer__discount-toggle-vertical" x1="12" y1="5" x2="12" y2="19"/>
              </svg>
            </span>
          </summary>
          <form class="cart-drawer__discount-form" data-discount-form>
            <input
              type="text"
              name="discount"
              class="cart-drawer__discount-input"
              placeholder="{{ 'sections.cart_drawer.discount_placeholder' | t }}"
              autocomplete="off"
              spellcheck="false"
              data-discount-input
            >
            <button type="submit" class="cart-drawer__discount-btn">
              {{ 'sections.cart_drawer.discount_apply' | t }}
            </button>
          </form>

          {%- if cart.cart_level_discount_applications.size > 0 -%}
            <ul class="cart-drawer__applied-discounts">
              {%- for discount in cart.cart_level_discount_applications -%}
                <li>{{ discount.title }} · −{{ discount.total_allocated_amount | money }}</li>
              {%- endfor -%}
            </ul>
          {%- endif -%}

          <p class="cart-drawer__discount-error" data-discount-error hidden>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span>{{ 'sections.cart_drawer.discount_invalid' | t }}</span>
          </p>
        </details>

        <div class="cart-drawer__totals">
          <div class="cart-drawer__row cart-drawer__row--total">
            <span>{{ 'sections.cart_drawer.total' | t }}</span>
            <span class="font-display cart-drawer__total-amount">{{ cart.total_price | money }}</span>
          </div>
        </div>

        <p class="cart-drawer__shipping-note">{{ 'sections.cart_drawer.shipping_note' | t }}</p>

        <a href="/checkout" class="cart-drawer__checkout">
          {{ 'sections.cart_drawer.checkout' | t }}
        </a>
        <a href="{{ routes.all_products_collection_url }}" class="cart-drawer__continue" data-cart-close>
          {{ 'sections.cart_drawer.continue_shopping' | t }}
        </a>
      </footer>
    {%- endif -%}
  </aside>
</div>

{% stylesheet %}
  .cart-drawer {
    position: fixed;
    inset: 0;
    z-index: 70;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  .cart-drawer[aria-hidden="false"] {
    opacity: 1;
    pointer-events: auto;
  }

  .cart-drawer__overlay {
    position: absolute;
    inset: 0;
    background-color: rgb(0 0 0 / 0.7);
  }

  .cart-drawer__panel {
    position: absolute;
    top: 0;
    right: 0;
    height: 100%;
    width: 100%;
    max-width: 440px;
    background-color: var(--background);
    border-left: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.5s ease;
  }

  .cart-drawer[aria-hidden="false"] .cart-drawer__panel {
    transform: translateX(0);
  }

  .cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    height: 5rem;
    border-bottom: 1px solid var(--border);
  }

  .cart-drawer__count {
    color: var(--primary);
    text-transform: none;
    letter-spacing: normal;
    margin-left: 0.25rem;
  }

  .cart-drawer__close {
    color: var(--foreground);
    display: inline-flex;
  }

  .cart-drawer__empty {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
  }

  .cart-drawer__empty-heading {
    font-size: 1.875rem;
    line-height: 1.15;
    color: color-mix(in oklab, var(--foreground) 90%, transparent);
  }

  .cart-drawer__empty-heading em {
    color: var(--primary);
    font-style: italic;
  }

  .cart-drawer__empty-body {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: var(--muted-foreground);
    max-width: 18rem;
    line-height: 1.5;
  }

  .cart-drawer__empty-cta {
    display: inline-block;
    margin-top: 2rem;
    padding: 1rem 2rem;
    border: 1px solid var(--primary);
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.75rem;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  .cart-drawer__empty-cta:hover {
    background-color: var(--primary);
    color: var(--primary-foreground);
  }

  .cart-drawer__items {
    flex: 1;
    overflow-y: auto;
    padding: 0;
    margin: 0;
  }

  .cart-drawer__item {
    display: flex;
    gap: 1rem;
    padding: 1.5rem 2rem;
    border-bottom: 1px solid var(--border);
    transition: opacity 0.2s ease;
  }

  .cart-drawer__item[data-loading="true"] {
    opacity: 0.5;
  }

  .cart-drawer__item[data-loading="true"] button {
    pointer-events: none;
  }

  .cart-drawer__item-image {
    display: block;
    width: 5rem;
    height: 6rem;
    flex-shrink: 0;
    background-color: var(--surface);
    overflow: hidden;
  }

  .cart-drawer__item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-drawer__item-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  .cart-drawer__item-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .cart-drawer__item-title {
    font-size: 1.125rem;
    line-height: 1.2;
    color: var(--foreground);
    transition: color 0.3s ease;
    flex: 1;
  }

  .cart-drawer__item-title:hover {
    color: var(--primary);
  }

  .cart-drawer__item-line-price {
    flex-shrink: 0;
    font-size: 0.875rem;
    color: var(--foreground);
    white-space: nowrap;
    padding-top: 0.25rem;
  }

  .cart-drawer__item-volume {
    margin-top: 0.4rem;
    font-size: 0.6875rem;
    color: var(--muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }

  .cart-drawer__item-unit-pricing {
    margin-top: 0.4rem;
    font-size: 0.8125rem;
    color: var(--foreground);
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .cart-drawer__item-compare {
    color: var(--muted-foreground);
    text-decoration: line-through;
    font-size: 0.75rem;
  }

  .cart-drawer__item-controls {
    margin-top: 0.875rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .cart-drawer__qty {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--border);
  }

  .cart-drawer__qty-btn {
    width: 2.25rem;
    height: 2.25rem;
    display: grid;
    place-items: center;
    color: var(--foreground);
    transition: color 0.3s ease;
  }

  .cart-drawer__qty-btn:hover {
    color: var(--primary);
  }

  .cart-drawer__qty-value {
    width: 2rem;
    text-align: center;
    font-size: 0.8125rem;
  }

  .cart-drawer__item-remove {
    width: 2.25rem;
    height: 2.25rem;
    display: grid;
    place-items: center;
    color: var(--muted-foreground);
    transition: color 0.3s ease;
  }

  .cart-drawer__item-remove:hover {
    color: var(--primary);
  }

  .cart-drawer__footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 2rem;
  }

  .cart-drawer__gift-options {
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }

  .cart-drawer__gift-summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 0.25rem;
    color: var(--foreground);
    font-size: 0.875rem;
  }

  .cart-drawer__gift-summary::-webkit-details-marker {
    display: none;
  }

  .cart-drawer__gift-summary-label {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }

  .cart-drawer__gift-summary-label svg {
    color: var(--primary);
    flex-shrink: 0;
  }

  .cart-drawer__gift-toggle {
    display: inline-flex;
    align-items: center;
    color: var(--foreground);
  }

  .cart-drawer__gift-toggle-vertical {
    transition: opacity 0.3s ease;
  }

  .cart-drawer__gift-options[open] .cart-drawer__gift-toggle-vertical {
    opacity: 0;
  }

  .cart-drawer__gift-message-field {
    margin-top: 0.875rem;
  }

  .cart-drawer__gift-message-field textarea {
    width: 100%;
    padding: 0.75rem 0.875rem;
    font-family: inherit;
    font-size: 0.8125rem;
    line-height: 1.55;
    background-color: var(--background);
    border: 1px solid var(--border);
    border-radius: 0;
    resize: none;
    color: var(--foreground);
    transition: border-color 0.3s ease;
  }

  .cart-drawer__gift-message-field textarea:focus {
    outline: none;
    border-color: var(--primary);
  }

  .cart-drawer__gift-message-meta {
    margin: 0.375rem 0 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 0.6875rem;
    color: color-mix(in oklab, var(--foreground) 55%, transparent);
  }

  .cart-drawer__gift-message-status {
    color: var(--primary);
    transition: opacity 0.3s ease;
  }

  /* === Discount === */
  .cart-drawer__discount {
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }

  .cart-drawer__discount-summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 0.25rem;
    color: var(--foreground);
    font-size: 0.875rem;
  }

  .cart-drawer__discount-summary::-webkit-details-marker {
    display: none;
  }

  .cart-drawer__discount-toggle {
    color: var(--foreground);
    display: inline-flex;
    align-items: center;
  }

  .cart-drawer__discount-toggle-vertical {
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }

  .cart-drawer__discount[open] .cart-drawer__discount-toggle-vertical {
    opacity: 0;
  }

  .cart-drawer__discount-form {
    margin-top: 0.875rem;
    display: flex;
    gap: 0.5rem;
  }

  .cart-drawer__discount-input {
    flex: 1;
    padding: 0.75rem 0.875rem;
    font-family: inherit;
    font-size: 0.875rem;
    background-color: var(--background);
    border: 1px solid var(--border);
    color: var(--foreground);
    border-radius: 0;
    transition: border-color 0.3s ease;
  }

  .cart-drawer__discount-input:focus {
    outline: none;
    border-color: var(--primary);
  }

  .cart-drawer__discount-btn {
    padding: 0 1.25rem;
    border: 0;
    background-color: var(--foreground);
    color: var(--background);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.6875rem;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .cart-drawer__discount-btn:hover,
  .cart-drawer__discount-btn:focus-visible {
    background-color: color-mix(in oklab, var(--foreground) 80%, transparent);
  }

  .cart-drawer__applied-discounts {
    list-style: none;
    margin: 0.75rem 0 0;
    padding: 0;
    font-size: 0.75rem;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }

  .cart-drawer__discount-error {
    margin: 0.75rem 0 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--destructive);
  }

  .cart-drawer__discount-error[hidden] {
    display: none;
  }

  .cart-drawer__discount-error svg {
    color: var(--destructive);
    flex-shrink: 0;
  }

  /* === Totals === */
  .cart-drawer__totals {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.875rem;
  }

  .cart-drawer__row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    color: color-mix(in oklab, var(--foreground) 80%, transparent);
  }

  .cart-drawer__row--total {
    color: var(--foreground);
  }

  .cart-drawer__total-amount {
    font-size: 1.5rem;
    color: var(--primary);
  }

  .cart-drawer__shipping-note {
    margin-top: 0.5rem;
    font-size: 0.75rem;
    color: var(--muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }

  .cart-drawer__checkout {
    display: block;
    width: 100%;
    margin-top: 1.5rem;
    padding: 1rem 2rem;
    background-color: var(--primary);
    color: var(--primary-foreground);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.75rem;
    font-weight: 500;
    transition: background-color 0.3s ease;
  }

  .cart-drawer__checkout:hover {
    background-color: var(--primary-glow);
  }

  .cart-drawer__continue {
    display: block;
    margin-top: 0.75rem;
    text-align: center;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: color-mix(in oklab, var(--foreground) 70%, transparent);
    transition: color 0.3s ease;
  }

  .cart-drawer__continue:hover {
    color: var(--primary);
  }
{% endstylesheet %}
