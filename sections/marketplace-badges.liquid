{%- liquid
  assign marketplaces = metaobjects.marketplace.values
  assign aria_heading = section.settings.heading | default: 'Also available on'

  assign visible_count = 0
  for mp in marketplaces
    assign key = mp.system.handle
    assign listing_url = product.metafields.marketplace[key].value
    if listing_url != blank
      assign visible_count = visible_count | plus: 1
    endif
  endfor

  assign use_preview = false
  if visible_count == 0 and section.settings.dev_preview
    assign use_preview = true
    assign preview_names = 'Amazon,Nykaa,Myntra,Flipkart' | split: ','
  endif
-%}

{%- if visible_count > 0 -%}
  <section class="marketplaces full-width" aria-label="{{ aria_heading | escape }}">
    <div class="marketplaces__inner cham-container">
      <div class="marketplaces__head" data-reveal>
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <p class="marketplaces__heading font-display">{{ section.settings.heading }}</p>
        {%- endif -%}
      </div>

      <ul class="marketplaces__list">
        {%- for mp in marketplaces -%}
          {%- assign key = mp.system.handle -%}
          {%- assign listing_url = product.metafields.marketplace[key].value -%}
          {%- if listing_url == blank -%}
            {%- continue -%}
          {%- endif -%}
          {%- assign mp_name = mp.name | default: key -%}
          <li class="marketplaces__item">
            <a
              href="{{ listing_url }}"
              class="marketplaces__link"
              target="_blank"
              rel="noopener noreferrer nofollow"
              aria-label="{{ 'sections.marketplaces.view_on' | t: name: mp_name }}"
              title="{{ 'sections.marketplaces.view_on' | t: name: mp_name }}"
            >
              {%- if mp.logo != blank -%}
                {{
                  mp.logo
                  | image_url: width: 360
                  | image_tag:
                    loading: 'lazy',
                    decoding: 'async',
                    class: 'marketplaces__logo',
                    alt: mp_name,
                    widths: '160, 320, 450',
                    sizes: '160px'
                }}
              {%- else -%}
                <span class="marketplaces__text">{{ mp_name }}</span>
              {%- endif -%}
            </a>
          </li>
        {%- endfor -%}
      </ul>

      {%- if section.settings.note != blank -%}
        <p class="marketplaces__note">{{ section.settings.note }}</p>
      {%- endif -%}
    </div>
  </section>
{%- elsif use_preview -%}
  <section class="marketplaces marketplaces--preview full-width" aria-label="{{ aria_heading | escape }}">
    {%- if request.design_mode -%}
      <p class="marketplaces__preview-flag">{{ 'sections.marketplaces.preview_flag' | t }}</p>
    {%- endif -%}
    <div class="marketplaces__inner cham-container">
      <div class="marketplaces__head">
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <p class="marketplaces__heading font-display">{{ section.settings.heading }}</p>
        {%- endif -%}
      </div>

      <ul class="marketplaces__list">
        {%- for name in preview_names -%}
          <li class="marketplaces__item">
            <span class="marketplaces__link marketplaces__link--preview">
              <span class="marketplaces__wordmark font-display">{{ name }}</span>
            </span>
          </li>
        {%- endfor -%}
      </ul>

      {%- if section.settings.note != blank -%}
        <p class="marketplaces__note">{{ section.settings.note }}</p>
      {%- endif -%}
    </div>
  </section>
{%- elsif request.design_mode -%}
  <section class="marketplaces marketplaces--placeholder full-width" aria-hidden="true">
    <div class="marketplaces__inner cham-container">
      <div class="marketplaces__placeholder">
        <p class="eyebrow">{{ 'sections.marketplaces.placeholder_eyebrow' | t }}</p>
        <p class="marketplaces__placeholder-text">{{ 'sections.marketplaces.placeholder_text' | t }}</p>
        <ol class="marketplaces__placeholder-steps">
          <li>{{ 'sections.marketplaces.placeholder_step_1' | t }}</li>
          <li>{{ 'sections.marketplaces.placeholder_step_2' | t }}</li>
          <li>{{ 'sections.marketplaces.placeholder_step_3' | t }}</li>
        </ol>
      </div>
    </div>
  </section>
{%- endif -%}

{% stylesheet %}
  /* Full-bleed tinted band — sits as the closer between PDP content and the
     site footer. Background extends edge-to-edge; content stays centered. */
  .marketplaces {
    width: 100%;
    background-color: var(--surface);
    /* Sits flush with the beige pillars band below; a hairline rule
       separates the two same-toned bands. */
    border-bottom: 1px solid var(--border);
    margin-top: 3rem;
    padding-block: 3.5rem;
  }

  @media (min-width: 1024px) {
    .marketplaces {
      margin-top: 4rem;
      padding-block: 3.5rem;
    }
  }

  /* External marketplace logos are designed for light backgrounds. In dark
     mode, re-anchor this single section to the light palette so logos read
     as their creators intended — the band becomes a deliberate light island
     above the footer, which doubles as a strong visual "trust signal" stop. */
  :root[data-theme="dark"] .marketplaces {
    --background: oklch(0.975 0.012 80);
    --foreground: oklch(0.18 0.01 60);
    --surface: oklch(0.945 0.018 78);
    --muted-foreground: oklch(0.40 0.02 60);
    --primary: oklch(0.58 0.13 70);
    --border: oklch(0.30 0.04 70 / 0.18);
    color: var(--foreground);
  }

  .marketplaces__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
  }

  @media (min-width: 1024px) {
    .marketplaces__inner {
      gap: 1.25rem;
    }
  }

  .marketplaces__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .marketplaces__heading {
    margin: 0;
    font-size: 1.125rem;
    line-height: 1.3;
    color: color-mix(in oklab, var(--foreground) 90%, transparent);
  }

  @media (min-width: 1024px) {
    .marketplaces__heading {
      font-size: 1.25rem;
    }
  }

  .marketplaces__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.625rem 0.875rem;
  }

  /* Each item is a fixed-size "slot" — keeps wide wordmarks (Amazon) and
     square marks (Myntra M) at comparable visual weight regardless of
     aspect ratio. */
  .marketplaces__item {
    width: 7rem;
    height: 2.75rem;
  }

  @media (min-width: 1024px) {
    .marketplaces__item {
      width: 9rem;
      height: 3.5rem;
    }
  }

  .marketplaces__link {
    display: flex;
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
    transition: opacity 0.25s ease, filter 0.25s ease;
  }

  .marketplaces__logo {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    /* Logos arrive in many brand colors — soften by default, restore on hover. */
    filter: grayscale(0.6);
    opacity: 0.9;
    transition: filter 0.25s ease, opacity 0.25s ease;
  }

  .marketplaces__link:hover .marketplaces__logo,
  .marketplaces__link:focus-visible .marketplaces__logo {
    filter: grayscale(0);
    opacity: 1;
  }

  .marketplaces__text {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--foreground) 75%, transparent);
  }

  .marketplaces__note {
    margin: 0;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--muted-foreground);
    max-width: 32rem;
  }

  /* Sample wordmarks — styled to read like flat logo lockups, never as real images. */
  .marketplaces--preview {
    position: relative;
  }

  .marketplaces__wordmark {
    font-size: 1.25rem;
    letter-spacing: 0.04em;
    color: color-mix(in oklab, var(--foreground) 60%, transparent);
    transition: color 0.25s ease;
  }

  @media (min-width: 1024px) {
    .marketplaces__wordmark {
      font-size: 1.5rem;
    }
  }

  .marketplaces__link--preview {
    cursor: default;
  }

  .marketplaces__link--preview:hover .marketplaces__wordmark {
    color: var(--primary);
  }

  /* Editor-only flag so the merchant remembers to turn dev preview off. */
  .marketplaces__preview-flag {
    margin: 0 auto 0.5rem;
    max-width: var(--page-max-width);
    padding-inline: var(--page-padding-inline);
    text-align: center;
    font-size: 0.625rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--primary);
  }

  /* Theme-editor only — visible to admins, never to shoppers. */
  .marketplaces--placeholder .marketplaces__inner {
    outline: 1px dashed var(--border);
    outline-offset: -1px;
  }

  .marketplaces__placeholder {
    max-width: 36rem;
    color: var(--muted-foreground);
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .marketplaces__placeholder-text {
    margin: 0.75rem 0 1rem;
  }

  .marketplaces__placeholder-steps {
    text-align: left;
    margin: 0;
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.marketplaces.name",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.marketplaces.info"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Also Available On"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.marketplaces.heading_label",
      "info": "t:sections.marketplaces.heading_info"
    },
    {
      "type": "text",
      "id": "note",
      "label": "t:sections.marketplaces.note_label",
      "info": "t:sections.marketplaces.note_info",
      "default": "Same Cham, same standards — wherever you choose to shop."
    },
    {
      "type": "header",
      "content": "t:sections.marketplaces.preview_header"
    },
    {
      "type": "checkbox",
      "id": "dev_preview",
      "label": "t:sections.marketplaces.dev_preview_label",
      "info": "t:sections.marketplaces.dev_preview_info",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "t:sections.marketplaces.presets_default"
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
