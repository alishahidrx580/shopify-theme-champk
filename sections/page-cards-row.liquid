{%- liquid
  assign block_count = section.blocks.size
  assign eyebrow = section.settings.eyebrow
  assign heading = section.settings.heading
  assign show_rule = section.settings.show_rule
-%}

<section
  class="page-cards-row full-width"
  style="--margin-top: {{ section.settings.margin_top }}rem; --margin-bottom: {{ section.settings.margin_bottom }}rem;"
>
  <div class="page-cards-row__inner">
    {%- if eyebrow != blank or heading != blank -%}
      <div class="page-cards-row__head" data-reveal>
        {%- if eyebrow != blank -%}
          <span class="page-cards-row__eyebrow">
            {%- if show_rule -%}<span class="page-cards-row__rule" aria-hidden="true"></span>{%- endif -%}
            <span class="eyebrow">{{ eyebrow }}</span>
          </span>
        {%- endif -%}
        {%- if heading != blank -%}
          <h2 class="page-cards-row__heading font-display">{{ heading }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="page-cards-row__grid is-count-{{ block_count }}">
      {%- for block in section.blocks -%}
        <div
          class="page-cards-row__card"
          data-reveal
          data-reveal-delay="{{ forloop.index0 | times: 90 }}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.title != blank -%}
            <h3 class="page-cards-row__title font-display">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.body != blank -%}
            <div class="page-cards-row__body">{{ block.settings.body }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .page-cards-row {
    width: 100%;
    margin-top: var(--margin-top, 6rem);
    margin-bottom: var(--margin-bottom, 8rem);
  }

  @media (min-width: 1024px) {
    .page-cards-row {
      margin-top: calc(var(--margin-top, 6rem) + 2rem);
    }
  }

  .page-cards-row__inner {
    max-width: 1100px;
    margin-inline: auto;
    padding-inline: var(--page-padding-inline);
  }

  @media (min-width: 1024px) {
    .page-cards-row__inner {
      padding-inline: var(--page-padding-inline-lg);
    }
  }

  /* Optional header */
  .page-cards-row__head {
    margin-bottom: 3rem;
  }

  .page-cards-row__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
  }

  .page-cards-row__rule {
    display: inline-block;
    width: 2.5rem;
    height: 1px;
    background-color: var(--primary);
    flex: none;
  }

  .page-cards-row__heading {
    margin-top: 1.25rem;
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  /* Cards */
  .page-cards-row__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .page-cards-row__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    /* Count-aware so 1–6 cards always balance. */
    .page-cards-row__grid.is-count-1 {
      grid-template-columns: minmax(0, 32rem);
    }
    .page-cards-row__grid.is-count-2,
    .page-cards-row__grid.is-count-4 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .page-cards-row__card {
    border-top: 1px solid var(--border);
    padding-top: 1.75rem;
  }

  .page-cards-row__title {
    font-size: clamp(1.5rem, 2.4vw, 1.875rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  .page-cards-row__body {
    margin-top: 0.875rem;
    font-size: 0.9375rem;
    color: color-mix(in oklab, var(--foreground) 75%, transparent);
    line-height: 1.7;
    text-wrap: pretty;
  }

  .page-cards-row__body > p { margin: 0; }
  .page-cards-row__body > p + p { margin-top: 0.75rem; }
{% endstylesheet %}

{% schema %}
{
  "name": "Cards row",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Header (optional)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "checkbox",
      "id": "show_rule",
      "label": "Show eyebrow rule",
      "info": "The short gold line before the eyebrow text.",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top margin (mobile)",
      "min": 0,
      "max": 16,
      "step": 1,
      "unit": "rem",
      "default": 6
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom margin",
      "min": 0,
      "max": 16,
      "step": 1,
      "unit": "rem",
      "default": 8
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Cards row"
    }
  ]
}
{% endschema %}
