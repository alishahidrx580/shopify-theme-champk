{%- liquid
  assign heading_lead = section.settings.heading_lead
  assign heading_emphasis = section.settings.heading_emphasis
  assign claim = section.settings.claim
  assign footnote = section.settings.footnote
  assign video = section.settings.video
  assign video_url = section.settings.video_url

  # ===== Poster / thumbnail resolution =====
  # Priority: per-product metafield image (if present) > section image setting.
  # This lets every product show its own thumbnail while keeping a shared fallback.
  assign image = section.settings.image
  assign poster_key = section.settings.poster_metafield | default: 'custom.feature_poster'
  assign poster_parts = poster_key | split: '.'
  assign poster_ns = poster_parts[0]
  assign poster_field = poster_parts[1]
  if product != blank and poster_ns != blank and poster_field != blank
    assign product_poster = product.metafields[poster_ns][poster_field].value
    if product_poster != blank
      assign image = product_poster
    endif
  endif

  assign media_position = section.settings.media_position | default: 'left'
  assign autoplay = section.settings.autoplay
  assign loop_video = section.settings.loop
  assign controls = section.settings.show_controls

  assign autoplay_flag = '0'
  if autoplay
    assign autoplay_flag = '1'
  endif
  assign loop_flag = '0'
  if loop_video
    assign loop_flag = '1'
  endif
  assign controls_flag = '0'
  if controls
    assign controls_flag = '1'
  endif
  assign vimeo_bg = '1'
  if controls
    assign vimeo_bg = '0'
  endif

  # Show the click-to-play poster only for Shopify-hosted video, when a poster
  # image exists and autoplay is OFF.
  assign use_poster = false
  if video != blank and image != blank and autoplay == false
    assign use_poster = true
  endif
-%}

<section class="product-feature-media full-width product-feature-media--media-{{ media_position }}">
  <div class="product-feature-media__inner cham-container">
    <div class="product-feature-media__grid">

      {%- comment -%} ===== Media (video / external embed / image) ===== {%- endcomment -%}
      <div class="product-feature-media__media{% if use_poster %} product-feature-media__media--has-poster{% endif %}" data-reveal data-feature-media>
        {%- if video != blank -%}
          {{ video | video_tag: image_size: '1200x', autoplay: autoplay, loop: loop_video, muted: true, controls: controls, playsinline: true, preload: 'metadata', class: 'product-feature-media__video', poster: image }}

          {%- if use_poster -%}
            <button type="button" class="product-feature-media__poster" data-feature-poster aria-label="Play video">
              <img
                src="{{ image | image_url: width: 1200 }}"
                srcset="{{ image | image_url: width: 600 }} 600w, {{ image | image_url: width: 1200 }} 1200w, {{ image | image_url: width: 1800 }} 1800w"
                sizes="(min-width: 1024px) 50vw, 100vw"
                alt="{{ heading_lead | escape }}"
                width="{{ image.width | default: 1200 }}"
                height="{{ image.height | default: 1500 }}"
                class="product-feature-media__poster-img"
                loading="lazy"
                decoding="async"
              >
              <span class="product-feature-media__play" aria-hidden="true">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
                  <polygon points="6 4 20 12 6 20 6 4"/>
                </svg>
              </span>
            </button>
          {%- endif -%}
        {%- elsif video_url != blank -%}
          <div class="product-feature-media__embed">
            {%- if video_url.type == 'youtube' -%}
              <iframe
                src="https://www.youtube.com/embed/{{ video_url.id }}?autoplay={{ autoplay_flag }}&mute=1&loop={{ loop_flag }}&playlist={{ video_url.id }}&controls={{ controls_flag }}&playsinline=1&modestbranding=1&rel=0"
                title="{{ heading_lead | escape }}"
                allow="autoplay; encrypted-media; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            {%- elsif video_url.type == 'vimeo' -%}
              <iframe
                src="https://player.vimeo.com/video/{{ video_url.id }}?autoplay={{ autoplay_flag }}&muted=1&loop={{ loop_flag }}&background={{ vimeo_bg }}&playsinline=1"
                title="{{ heading_lead | escape }}"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            {%- endif -%}
          </div>
        {%- elsif image != blank -%}
          <img
            src="{{ image | image_url: width: 1200 }}"
            srcset="{{ image | image_url: width: 600 }} 600w, {{ image | image_url: width: 1200 }} 1200w, {{ image | image_url: width: 1800 }} 1800w"
            sizes="(min-width: 1024px) 50vw, 100vw"
            alt="{{ heading_lead | escape }}"
            width="{{ image.width | default: 1200 }}"
            height="{{ image.height | default: 1500 }}"
            class="product-feature-media__img"
            loading="lazy"
            decoding="async"
          >
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'product-feature-media__img product-feature-media__img--placeholder' }}
        {%- endif -%}
      </div>

      {%- comment -%} ===== Text ===== {%- endcomment -%}
      <div class="product-feature-media__text" data-reveal data-reveal-delay="120">
        {%- if section.settings.eyebrow != blank -%}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="product-feature-media__heading font-display">
          {{- heading_lead -}}
          {%- if heading_emphasis != blank %} <em>{{ heading_emphasis }}</em>{%- endif -%}
        </h2>
        {%- if claim != blank -%}
          <p class="product-feature-media__claim">{{ claim }}</p>
        {%- endif -%}
        {%- if footnote != blank -%}
          <div class="product-feature-media__footnote rte">{{ footnote }}</div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% stylesheet %}
  .product-feature-media {
    width: 100%;
    padding-block: 5rem;
  }

  @media (min-width: 1024px) {
    .product-feature-media {
      padding-block: 8rem;
    }
  }

  .product-feature-media__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .product-feature-media__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 4.5rem;
    }
  }

  /* === Media === */
  .product-feature-media__media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background-color: var(--surface);
  }

  .product-feature-media__video,
  .product-feature-media__img,
  .product-feature-media__media video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-feature-media__embed,
  .product-feature-media__embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .product-feature-media__img--placeholder {
    color: color-mix(in oklab, var(--primary) 30%, var(--surface));
  }

  /* === Poster (click-to-play thumbnail) === */
  .product-feature-media__poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    padding: 0;
    border: 0;
    cursor: pointer;
    background: none;
    display: block;
    z-index: 2;
    transition: opacity 0.4s ease;
  }

  .product-feature-media__poster-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-feature-media__play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 5rem;
    height: 5rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background-color: color-mix(in oklab, var(--background) 90%, transparent);
    color: var(--primary);
    box-shadow: 0 20px 60px -20px color-mix(in oklab, var(--primary) 35%, transparent);
    transition: transform 0.4s cubic-bezier(0.2, 0.6, 0.2, 1), background-color 0.3s ease;
  }

  .product-feature-media__play svg { margin-left: 4px; }

  .product-feature-media__poster:hover .product-feature-media__play {
    transform: translate(-50%, -50%) scale(1.06);
    background-color: var(--background);
  }

  .product-feature-media__poster:focus-visible {
    outline: 2px solid var(--ring, var(--primary));
    outline-offset: -4px;
  }

  /* Hidden once playback starts */
  .product-feature-media__media--has-poster.is-playing .product-feature-media__poster {
    opacity: 0;
    pointer-events: none;
  }

  /* Media side: left by default, right when toggled (desktop only). */
  @media (min-width: 1024px) {
    .product-feature-media--media-right .product-feature-media__media { order: 2; }
  }

  /* === Text === */
  .product-feature-media__heading {
    margin-top: 1.5rem;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 300;
    line-height: 1.0;
    letter-spacing: -0.015em;
    text-transform: uppercase;
  }

  .product-feature-media__heading em {
    color: var(--primary);
    font-style: italic;
    text-transform: none;
  }

  .product-feature-media__claim {
    margin-top: 1.75rem;
    font-size: 1.0625rem;
    line-height: 1.5;
    color: color-mix(in oklab, var(--foreground) 90%, transparent);
  }

  .product-feature-media__footnote {
    margin-top: 1.5rem;
    max-width: 34rem;
    color: var(--muted-foreground);
    line-height: 1.7;
    font-size: 0.9375rem;
  }

  .product-feature-media__footnote > p { margin: 0; }
  .product-feature-media__footnote > p + p { margin-top: 1rem; }
{% endstylesheet %}

{% javascript %}
  (function () {
    document.querySelectorAll('[data-feature-media]').forEach(function (media) {
      var poster = media.querySelector('[data-feature-poster]');
      var video = media.querySelector('video');
      if (!poster || !video) return;

      poster.addEventListener('click', function () {
        media.classList.add('is-playing');
        if (!video.hasAttribute('controls')) video.setAttribute('controls', '');
        var p = video.play();
        if (p && p.catch) p.catch(function () {});
      });

      video.addEventListener('pause', function () {
        if (video.currentTime === 0) media.classList.remove('is-playing');
      });
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Feature media (video)",
  "tag": "section",
  "settings": [
    {
      "type": "select",
      "id": "media_position",
      "label": "Media position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow"
    },
    {
      "type": "text",
      "id": "heading_lead",
      "label": "t:labels.heading_lead",
      "default": "Shake to Rejuvenate"
    },
    {
      "type": "text",
      "id": "heading_emphasis",
      "label": "t:labels.heading_emphasis"
    },
    {
      "type": "text",
      "id": "claim",
      "label": "Claim line"
    },
    {
      "type": "richtext",
      "id": "footnote",
      "label": "Footnote"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "paragraph",
      "content": "Use a Shopify-hosted video for the best edge-to-edge fit and the click-to-play thumbnail. A YouTube/Vimeo link or an image can be used instead. If more than one is set, video wins, then the external link, then the image."
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video (Shopify-hosted)"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Video link (YouTube or Vimeo)",
      "accept": ["youtube", "vimeo"]
    },
    {
      "type": "text",
      "id": "poster_metafield",
      "label": "Per-product poster metafield",
      "info": "namespace.key of a product image metafield used as the per-product thumbnail. Falls back to the image below when a product has no value. Default: custom.feature_poster",
      "default": "custom.feature_poster"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Thumbnail / poster image (fallback)",
      "info": "Used when a product has no poster metafield value. Shown before the video plays (Shopify-hosted video, with Autoplay off). Also used as the image fallback."
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay (muted)",
      "info": "Turn OFF to show the thumbnail with a play button (click to play).",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show playback controls",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Feature media (video)"
    }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
